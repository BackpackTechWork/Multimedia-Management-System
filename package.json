{
  "name": "harbor-drive",
  "version": "1.0.0",
  "description": "Harbor Drive",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "build:css": "tailwindcss -i src/css/auth.css -o public/css/auth.css --minify && tailwindcss -i src/css/drive.css -o public/css/drive.css --minify && tailwindcss -i src/css/preview.css -o public/css/preview.css --minify",
    "watch:css": "tailwindcss -i src/css/drive.css -o public/css/drive.css --watch",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "setup:vendors": "node scripts/setup-vendors.js"
  },
  "dependencies": {
    "@fontsource/inter": "^5.0.17",
    "bcrypt": "^5.1.1",
    "bootstrap-icons": "^1.11.3",
    "compression": "^1.7.4",
    "csurf": "^1.11.0",
    "docx-preview": "^0.4.0",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.30.10",
    "ejs": "^3.1.10",
    "excel-viewer": "^1.0.1",
    "express": "^4.19.2",
    "express-rate-limit": "^7.2.0",
    "express-session": "^1.18.0",
    "helmet": "^7.1.0",
    "js-beautify": "^1.15.1",
    "jszip": "^3.10.1",
    "lightgallery": "^2.7.2",
    "marked": "^12.0.1",
    "mime-types": "^2.1.35",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.9.7",
    "pdfjs-dist": "3.11.174",
    "pptx-preview": "^1.0.7",
    "sharp": "^0.33.3",
    "yauzl": "^3.4.0"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.19",
    "drizzle-kit": "^0.21.4",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.3"
  }
}
