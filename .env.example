# Server Configuration
PORT=3000
NODE_ENV=development

# Database Configuration
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=drive_clone

# Session configuration
SESSION_SECRET=super_secret_session_key_change_me_in_production

# Storage settings
# Chunks will be stored at: STORAGE_ROOT/.chunks
# Thumbnails will be stored at: STORAGE_ROOT/.thumbnails
STORAGE_ROOT=./storage

# System-wide storage limit in Gigabytes (leave empty or delete for unlimited)
MAX_SYSTEM_STORAGE_GB=15
