<%- include('../partials/header') %>

<%
  const isEditorLink = share.linkRole === 'editor';
  const isRestrictedLink = share.linkAccess === 'restricted';
  const accessLabel = isRestrictedLink ? 'Restricted' : 'Anyone with link';
  const roleLabel = isEditorLink ? 'Editor' : 'Viewer';
  function previewRouteFor(targetFile) {
    const mimeType = targetFile.mimeType || '';
    const extension = (targetFile.extension || '').toLowerCase();
    if (mimeType.startsWith('image/')) return 'image';
    if (mimeType === 'application/pdf') return 'pdf';
    if (mimeType.startsWith('video/')) return 'video';
    if (mimeType.startsWith('audio/')) return 'audio';
    if (extension === 'md') return 'markdown';
    if (['doc', 'docx'].includes(extension) || mimeType === 'application/msword' || mimeType === 'application/vnd.openxmlformats-officedocument.wordprocessingml.document') return 'word';
    if (['xls', 'xlsx', 'csv', 'ods'].includes(extension)) return 'excel';
    if (['ppt', 'pptx'].includes(extension) || mimeType === 'application/vnd.ms-powerpoint' || mimeType === 'application/vnd.openxmlformats-officedocument.presentationml.presentation') return 'presentation';
    if (extension === 'zip' || mimeType === 'application/zip' || mimeType === 'application/x-zip-compressed') return 'zip';
    return 'code';
  }
%>

<div class="share-page flex-1 flex flex-col">
  <header class="share-topbar select-none">
    <a href="/share/<%= token %>" class="flex items-center gap-3 min-w-0 group">
      <img src="/web-app-manifest-512x512.png" alt="Harbor Drive" class="h-10 w-10 rounded-lg shadow-sm object-cover shrink-0 transition-transform group-hover:scale-105">
      <span class="text-lg sm:text-xl font-bold tracking-tight text-brand-dark-grey truncate">
        Harbor <span class="text-brand-teal font-medium">Drive</span>
      </span>
    </a>
    <div class="hidden sm:flex items-center gap-2 text-xs font-semibold text-gray-500">
      <span class="share-pill"><i class="bi bi-shield-check text-brand-teal"></i><%= accessLabel %></span>
      <span class="share-pill"><i class="bi bi-eye text-brand-teal"></i><%= roleLabel %></span>
    </div>
  </header>

  <main class="share-main flex-1 animate-fade-up">
    <div class="share-crumbbar select-none">
      <nav class="flex items-center flex-wrap gap-1.5 text-sm font-semibold text-gray-500 min-w-0" aria-label="Shared folder path">
        <a href="/share/<%= token %>" class="hover:text-brand-teal text-gray-500 transition flex items-center gap-1">
          <i class="bi bi-folder-fill text-yellow-500 text-base"></i>
          <span><%= (breadcrumbs && breadcrumbs.length > 0) ? breadcrumbs[0].name : (folder ? folder.name : 'Shared root') %></span>
        </a>
        <% if (breadcrumbs && breadcrumbs.length > 1) { %>
          <% breadcrumbs.slice(1).forEach((crumb, idx) => { %>
            <i class="bi bi-chevron-right text-gray-300 text-xs"></i>
            <% if (idx === breadcrumbs.length - 2) { %>
              <span class="text-gray-800 font-bold truncate max-w-xs"><%= crumb.name %></span>
            <% } else { %>
              <a href="/share/<%= token %>/folders/<%= crumb.id %>" class="hover:text-brand-teal transition truncate max-w-xs"><%= crumb.name %></a>
            <% } %>
          <% }) %>
        <% } %>
      </nav>
      <div class="flex sm:hidden items-center gap-2 text-xs font-semibold text-gray-500">
        <span class="share-pill"><i class="bi bi-eye text-brand-teal"></i><%= roleLabel %></span>
      </div>
    </div>

    <% if (!isFolder && file) { %>
      <% 
        let iconClass = 'bi-file-earmark-fill text-gray-400';
        if (file.extension === 'pdf') iconClass = 'bi-file-pdf-fill text-red-500';
        else if (['doc', 'docx'].includes(file.extension)) iconClass = 'bi-file-word-fill text-blue-500';
        else if (['xls', 'xlsx', 'csv'].includes(file.extension)) iconClass = 'bi-file-excel-fill text-green-600';
        else if (['js', 'ts', 'html', 'css', 'json', 'sql'].includes(file.extension)) iconClass = 'bi-file-code-fill text-gray-600';
        else if (file.extension === 'md') iconClass = 'bi-markdown-fill text-indigo-500';
        else if (file.mimeType.startsWith('image/')) iconClass = 'bi-file-image-fill text-purple-500';
        else if (file.mimeType.startsWith('audio/')) iconClass = 'bi-file-music-fill text-pink-500';
        else if (file.mimeType.startsWith('video/')) iconClass = 'bi-file-play-fill text-red-600';
      %>

      <section class="share-file-panel mt-6">
        <div class="flex items-center gap-4 min-w-0">
          <div class="share-icon-box shadow-sm">
            <i class="bi <%= iconClass %> text-4xl"></i>
          </div>
          <div class="min-w-0">
            <h1 class="text-xl font-bold text-gray-800 truncate" title="<%= file.originalName %>"><%= file.originalName %></h1>
            <div class="share-meta-row mt-2.5">
              <span class="share-pill"><i class="bi bi-file-earmark text-brand-teal"></i><%= (file.extension || 'file').toUpperCase() %></span>
              <span class="share-pill"><i class="bi bi-hdd text-brand-teal"></i><%= formatBytes(file.size) %></span>
              <span class="share-pill"><i class="bi bi-shield-check text-brand-teal"></i><%= accessLabel %></span>
            </div>
          </div>
        </div>

        <div class="flex flex-col sm:flex-row gap-3">
          <a href="/preview/<%= previewRouteFor(file) %>/<%= file.id %>?shareToken=<%= encodeURIComponent(token) %>" class="inline-flex items-center justify-center gap-2 bg-brand-teal text-white py-3 px-6 rounded-lg font-bold hover:bg-brand-teal-dark active:scale-[0.98] transition shadow-sm hover:shadow">
            <i class="bi bi-eye"></i>
            <span>Preview</span>
          </a>
          <% if (share.allowDownload) { %>
            <a href="/share/<%= token %>/download" class="inline-flex items-center justify-center gap-2 border border-gray-200 bg-white text-gray-700 py-3 px-6 rounded-lg font-bold hover:bg-gray-50 active:scale-[0.98] transition shadow-sm hover:shadow">
              <i class="bi bi-download"></i>
              <span>Download</span>
            </a>
          <% } else { %>
            <button disabled class="inline-flex items-center justify-center gap-2 bg-gray-100 text-gray-400 py-3 px-6 rounded-lg font-bold cursor-not-allowed">
              <i class="bi bi-lock"></i>
              <span>Download disabled</span>
            </button>
          <% } %>
        </div>
      </section>
    <% } else if (isFolder && contents) { %>
      <section class="mt-6">
        <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4">
          <div>
            <div class="flex items-center gap-2.5">
              <h1 class="text-2xl font-bold text-gray-800"><%= folder ? folder.name : 'Shared folder' %></h1>
              <% if (isEditorLink) { %>
                <div class="relative inline-block text-left" id="upload-dropdown-container">
                  <button type="button" id="upload-dropdown-btn" class="inline-flex items-center justify-center h-8 w-8 rounded-full border border-gray-200 bg-white text-gray-600 hover:text-brand-teal hover:border-brand-teal active:scale-95 transition shadow-sm hover:shadow" aria-haspopup="true" aria-expanded="false" title="Upload options">
                    <i class="bi bi-three-dots-vertical text-base"></i>
                  </button>
                  <div id="upload-dropdown-menu" class="hidden absolute left-0 mt-2 w-48 rounded-lg shadow-lg bg-white border border-gray-100 py-1 z-50 origin-top-left">
                    <button type="button" id="upload-files-item" class="w-full text-left px-4 py-2.5 text-sm text-gray-700 hover:bg-gray-50 hover:text-brand-teal flex items-center gap-2.5 transition">
                      <i class="bi bi-file-earmark-arrow-up text-brand-teal text-base"></i>
                      <span>Upload files</span>
                    </button>
                    <button type="button" id="upload-folder-item" class="w-full text-left px-4 py-2.5 text-sm text-gray-700 hover:bg-gray-50 hover:text-brand-teal flex items-center gap-2.5 transition">
                      <i class="bi bi-folder-symlink text-brand-teal text-base"></i>
                      <span>Upload folder</span>
                    </button>
                  </div>
                  <!-- Hidden native file inputs -->
                  <input type="file" id="hidden-files-input" multiple class="hidden">
                  <input type="file" id="hidden-folder-input" webkitdirectory directory multiple class="hidden">
                </div>
              <% } %>
            </div>
            <p class="text-sm text-gray-500 mt-1">Files and folders shared through Harbor Drive.</p>
          </div>
          <div class="share-meta-row">
            <span class="share-pill"><i class="bi bi-folder2-open text-brand-teal"></i><%= contents.folders.length %> folder<%= contents.folders.length === 1 ? '' : 's' %></span>
            <span class="share-pill"><i class="bi bi-files text-brand-teal"></i><%= contents.files.length %> file<%= contents.files.length === 1 ? '' : 's' %></span>
          </div>
        </div>
      </section>

      <% if (contents.folders.length === 0 && contents.files.length === 0) { %>
        <div class="share-empty-state">
          <div class="share-icon-box mb-4 shadow-sm bg-gray-50">
            <i class="bi bi-folder2-open text-4xl text-gray-300"></i>
          </div>
          <h2 class="text-lg font-bold text-gray-700">Folder is empty</h2>
          <p class="text-sm text-gray-500 max-w-sm mt-1">The owner has not uploaded files inside this shared directory.</p>
        </div>
      <% } %>

      <% if (contents.folders.length > 0) { %>
        <section class="share-section">
          <div class="share-section-heading">
            <h2 class="text-sm font-bold text-gray-700">Folders</h2>
            <span class="text-xs font-semibold text-gray-400 bg-gray-100 px-2 py-0.5 rounded-full"><%= contents.folders.length %> total</span>
          </div>
          <div class="share-card-grid">
            <% contents.folders.forEach(sub => { %>
              <a href="/share/<%= token %>/folders/<%= sub.id %>" class="share-item-card share-folder-card group select-none">
                <span class="share-item-preview h-10 w-10 shrink-0 shadow-sm border border-gray-100">
                  <i class="bi bi-folder-fill text-2xl text-yellow-500 transition-transform group-hover:scale-105"></i>
                </span>
                <span class="font-semibold text-sm text-gray-700 truncate group-hover:text-brand-teal transition-colors"><%= sub.name %></span>
              </a>
            <% }) %>
          </div>
        </section>
      <% } %>

      <% if (contents.files.length > 0) { %>
        <section class="share-section">
          <div class="share-section-heading">
            <h2 class="text-sm font-bold text-gray-700">Files</h2>
            <span class="text-xs font-semibold text-gray-400 bg-gray-100 px-2 py-0.5 rounded-full"><%= contents.files.length %> total</span>
          </div>
          <div class="share-card-grid">
            <% contents.files.forEach(f => { %>
              <% 
                let fileIconClass = 'bi-file-earmark-fill text-gray-400';
                if (f.extension === 'pdf') fileIconClass = 'bi-file-pdf-fill text-red-500';
                else if (['doc', 'docx'].includes(f.extension)) fileIconClass = 'bi-file-word-fill text-blue-500';
                else if (['xls', 'xlsx', 'csv'].includes(f.extension)) fileIconClass = 'bi-file-excel-fill text-green-600';
                else if (['js', 'ts', 'html', 'css', 'json', 'sql'].includes(f.extension)) fileIconClass = 'bi-file-code-fill text-gray-600';
                else if (f.extension === 'md') fileIconClass = 'bi-markdown-fill text-indigo-500';
                else if (f.mimeType.startsWith('audio/')) fileIconClass = 'bi-file-music-fill text-pink-500';
                else if (f.mimeType.startsWith('video/')) fileIconClass = 'bi-file-play-fill text-red-600';
              %>
              <div class="share-item-card share-file-card group cursor-pointer select-none" data-preview-url="/preview/<%= previewRouteFor(f) %>/<%= f.id %>?shareToken=<%= encodeURIComponent(token) %>">
                <div class="share-item-preview h-28 w-full overflow-hidden shadow-inner border border-gray-100">
                  <% if (f.mimeType.startsWith('image/')) { %>
                    <img src="/share/<%= token %>/download?fileId=<%= f.id %>" alt="<%= f.originalName %>" class="w-full h-full object-cover" loading="lazy">
                  <% } else { %>
                    <i class="bi <%= fileIconClass %> text-5xl transition-transform group-hover:scale-105"></i>
                  <% } %>
                </div>
                <div class="flex items-center justify-between gap-2 min-w-0 mt-3">
                  <div class="min-w-0">
                    <p class="font-bold text-sm text-gray-700 truncate group-hover:text-brand-teal transition-colors" title="<%= f.originalName %>"><%= f.originalName %></p>
                    <p class="text-xs text-gray-400 font-semibold mt-0.5"><%= formatBytes(f.size) %></p>
                  </div>
                  <div class="flex items-center gap-2 shrink-0">
                    <a href="/preview/<%= previewRouteFor(f) %>/<%= f.id %>?shareToken=<%= encodeURIComponent(token) %>" title="Preview file" class="inline-flex items-center justify-center h-8 w-8 rounded-lg bg-brand-teal text-white hover:bg-brand-teal-dark active:scale-95 transition shadow-sm hover:shadow">
                      <i class="bi bi-eye text-sm"></i>
                    </a>
                    <% if (share.allowDownload) { %>
                      <a href="/share/<%= token %>/download?fileId=<%= f.id %>" title="Download file" class="inline-flex items-center justify-center h-8 w-8 rounded-lg border border-gray-200 bg-white text-gray-600 hover:text-brand-teal hover:border-brand-teal active:scale-95 transition shadow-sm hover:shadow">
                        <i class="bi bi-download text-sm"></i>
                      </a>
                    <% } else { %>
                      <span title="Download disabled" class="inline-flex items-center justify-center h-8 w-8 rounded-lg bg-gray-100 text-gray-400 cursor-not-allowed">
                        <i class="bi bi-lock text-sm"></i>
                      </span>
                    <% } %>
                  </div>
                </div>
              </div>
            <% }) %>
          </div>
        </section>
      <% } %>
    <% } %>
  </main>
</div>
  <!-- Drag and drop overlay -->
  <% if (isEditorLink) { %>
    <div id="drag-overlay" class="fixed inset-0 bg-brand-teal/80 backdrop-blur-[2px] z-[9999] hidden flex-col items-center justify-center text-white pointer-events-none transition-all duration-300">
      <div class="flex flex-col items-center gap-4 animate-bounce">
        <i class="bi bi-cloud-arrow-up-fill text-6xl"></i>
        <span class="text-2xl font-bold">Drop items here to upload to this shared folder</span>
      </div>
    </div>

    <!-- Upload Progress Widget (Same as dashboard index/modals) -->
    <div id="upload-progress-modal" class="fixed bottom-4 right-4 md:right-4 left-4 md:left-auto bg-white border border-gray-200 shadow-xl rounded-xl w-[calc(100%-2rem)] md:w-[28rem] hidden z-50 select-none mx-4 md:mx-0 overflow-hidden transition-all duration-300 transform translate-y-10 opacity-0">
      <div class="flex items-center justify-between px-4 py-3 border-b border-gray-100">
        <div class="min-w-0">
          <span id="upload-progress-text" class="block text-sm font-bold text-gray-800 truncate">Preparing upload...</span>
          <span id="upload-progress-details" class="block text-[11px] text-gray-500 mt-0.5">0% - Calculating time left</span>
        </div>
        <div class="flex items-center">
          <button id="upload-progress-toggle-btn" class="p-2 text-gray-500 hover:text-gray-800 hover:bg-gray-100 rounded-md transition" title="Collapse upload list">
            <i class="bi bi-chevron-down text-base"></i>
          </button>
          <button id="upload-progress-close-btn" class="p-2 -mr-2 text-gray-500 hover:text-gray-800 hover:bg-gray-100 rounded-md transition" title="Cancel upload">
            <i class="bi bi-x-lg text-base"></i>
          </button>
        </div>
      </div>
      <div id="upload-progress-body" class="transition-all duration-300">
        <div class="h-1 bg-gray-100 overflow-hidden">
          <div id="upload-progress-bar" class="bg-brand-teal h-1 transition-[width] duration-150 ease-out" style="width: 0%"></div>
        </div>
        <div id="upload-queue-list" class="max-h-72 overflow-y-auto py-2 px-4 flex flex-col gap-2">
          <!-- Populated dynamically -->
        </div>
      </div>
    </div>
  <% } %>

<script>
  function formatBytes(bytes) {
    if (!bytes || bytes == 0) return '0 Bytes';
    const k = 1024;
    const sizes = ['Bytes', 'KB', 'MB', 'GB', 'TB'];
    const i = Math.floor(Math.log(bytes) / Math.log(k));
    return parseFloat((bytes / Math.pow(k, i)).toFixed(2)) + ' ' + sizes[i];
  }

  document.addEventListener('DOMContentLoaded', () => {
    // Double click handler for file cards
    document.querySelectorAll('.share-file-card').forEach(card => {
      card.addEventListener('dblclick', () => {
        const previewUrl = card.dataset.previewUrl;
        if (previewUrl) {
          window.location.href = previewUrl;
        }
      });
    });

    <% if (isEditorLink) { %>
      const dropdownBtn = document.getElementById('upload-dropdown-btn');
      const dropdownMenu = document.getElementById('upload-dropdown-menu');
      const uploadFilesItem = document.getElementById('upload-files-item');
      const uploadFolderItem = document.getElementById('upload-folder-item');
      const hiddenFilesInput = document.getElementById('hidden-files-input');
      const hiddenFolderInput = document.getElementById('hidden-folder-input');

      // Toggle dropdown
      if (dropdownBtn) {
        dropdownBtn.addEventListener('click', (e) => {
          e.stopPropagation();
          dropdownMenu.classList.toggle('hidden');
        });
      }

      // Close dropdown when clicking outside
      document.addEventListener('click', () => {
        if (dropdownMenu && !dropdownMenu.classList.contains('hidden')) {
          dropdownMenu.classList.add('hidden');
        }
      });

      // Upload files trigger
      if (uploadFilesItem) {
        uploadFilesItem.addEventListener('click', () => {
          hiddenFilesInput.click();
        });
      }

      // Upload folder trigger
      if (uploadFolderItem) {
        uploadFolderItem.addEventListener('click', () => {
          hiddenFolderInput.click();
        });
      }

      // Handle file selection
      if (hiddenFilesInput) {
        hiddenFilesInput.addEventListener('change', () => {
          uploadFiles(Array.from(hiddenFilesInput.files));
          hiddenFilesInput.value = '';
        });
      }

      // Handle folder selection
      if (hiddenFolderInput) {
        hiddenFolderInput.addEventListener('change', () => {
          uploadFiles(Array.from(hiddenFolderInput.files));
          hiddenFolderInput.value = '';
        });
      }

      // Drag and drop anywhere
      let dragCounter = 0;
      const dragOverlay = document.getElementById('drag-overlay');

      window.addEventListener('dragenter', (e) => {
        e.preventDefault();
        dragCounter++;
        if (dragCounter === 1 && dragOverlay) {
          dragOverlay.classList.remove('hidden');
          dragOverlay.classList.add('flex');
        }
      });

      window.addEventListener('dragleave', (e) => {
        e.preventDefault();
        dragCounter--;
        if (dragCounter === 0 && dragOverlay) {
          dragOverlay.classList.add('hidden');
          dragOverlay.classList.remove('flex');
        }
      });

      window.addEventListener('dragover', (e) => {
        e.preventDefault();
      });

      window.addEventListener('drop', async (e) => {
        e.preventDefault();
        dragCounter = 0;
        if (dragOverlay) {
          dragOverlay.classList.add('hidden');
          dragOverlay.classList.remove('flex');
        }
        
        const filesList = await getFilesFromDroppedItems(e.dataTransfer);
        if (filesList.length > 0) {
          uploadFiles(filesList);
        }
      });

      function setDroppedRelativePath(file, relativePath) {
        if (!relativePath) return file;

        try {
          Object.defineProperty(file, 'relativePath', {
            value: relativePath,
            configurable: true
          });
        } catch (err) {
          file.relativePath = relativePath;
        }

        return file;
      }

      function getFileRelativePath(file) {
        return file.relativePath || file.webkitRelativePath || '';
      }

      function wait(ms) {
        return new Promise(resolve => setTimeout(resolve, ms));
      }

      function getRetryDelay(response, attempt) {
        const retryAfter = parseInt(response?.headers?.get('Retry-After') || '', 10);
        return Number.isFinite(retryAfter)
          ? retryAfter * 1000
          : Math.min(30000, 1500 * attempt);
      }

      // Helper function to recursively read files from dropped directories
      async function getFilesFromDroppedItems(dataTransfer) {
        const filesList = [];
        let skippedEntries = 0;

        function recordSkippedEntry(entry, err) {
          skippedEntries++;
          const entryName = entry?.fullPath || entry?.name || 'Unknown entry';
          console.warn(`Skipping dropped item "${entryName}":`, err);
        }
        
        if (dataTransfer.items && dataTransfer.items.length > 0) {
          async function traverseEntry(entry, parentPath = '') {
            const entryPath = parentPath ? `${parentPath}/${entry.name}` : entry.name;

            if (entry.isFile) {
              let file;
              try {
                file = await new Promise((resolve, reject) => entry.file(resolve, reject));
              } catch (err) {
                recordSkippedEntry(entry, err);
                return;
              }
              setDroppedRelativePath(file, entryPath);
              filesList.push(file);
            } else if (entry.isDirectory) {
              const dirReader = entry.createReader();
              const readAllEntries = async () => {
                let allEntries = [];
                let results = await new Promise((resolve, reject) => dirReader.readEntries(resolve, reject));
                while (results.length > 0) {
                  allEntries = allEntries.concat(results);
                  results = await new Promise((resolve, reject) => dirReader.readEntries(resolve, reject));
                }
                return allEntries;
              };
              
              const entries = await readAllEntries().catch((err) => {
                recordSkippedEntry(entry, err);
                return [];
              });
              for (const subEntry of entries) {
                await traverseEntry(subEntry, entryPath);
              }
            }
          }
          
          for (const item of dataTransfer.items) {
            const entry = item.webkitGetAsEntry ? item.webkitGetAsEntry() : null;
            if (entry) {
              await traverseEntry(entry);
            } else {
              const file = item.getAsFile ? item.getAsFile() : null;
              if (file) filesList.push(file);
            }
          }
        } else if (dataTransfer.files) {
          for (const file of dataTransfer.files) {
            filesList.push(file);
          }
        }

        if (skippedEntries > 0) {
          console.warn(`${skippedEntries} unreadable dropped item${skippedEntries === 1 ? '' : 's'} skipped.`);
        }
        
        return filesList;
      }

      // XHR upload single file function
      function uploadSingleFile(file, folderId, onProgress, { deferStats = false, attempt = 1 } = {}) {
        return new Promise((resolve, reject) => {
          const xhr = new XMLHttpRequest();
          xhr.open('POST', '/share/<%= token %>/upload');
          xhr.setRequestHeader('Accept', 'application/json');
          
          xhr.upload.onprogress = (e) => {
            if (e.lengthComputable) {
              const percent = Math.round((e.loaded / e.total) * 100);
              onProgress(percent);
            }
          };
          
          xhr.onload = () => {
            if (xhr.status >= 200 && xhr.status < 400) {
              resolve();
            } else if (xhr.status === 429 && attempt < 5) {
              const retryAfter = parseInt(xhr.getResponseHeader('Retry-After') || '', 10);
              const retryDelay = Number.isFinite(retryAfter)
                ? retryAfter * 1000
                : Math.min(30000, 1500 * attempt);
              setTimeout(() => {
                uploadSingleFile(file, folderId, onProgress, { deferStats, attempt: attempt + 1 }).then(resolve, reject);
              }, retryDelay);
            } else {
              reject(new Error(`Upload failed with status ${xhr.status}`));
            }
          };
          
          xhr.onerror = () => {
            reject(new Error('Network error during upload'));
          };
          
          const formData = new FormData();
          formData.append('file', file);
          formData.append('folderId', folderId || '');
          formData.append('deferStats', deferStats ? 'true' : 'false');
          
          xhr.send(formData);
        });
      }

      // XHR create shared folder function
      async function createFolderOnServer(name, parentId, { deferStats = false, attempt = 1 } = {}) {
        const res = await fetch('/share/<%= token %>/folders', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json'
          },
          body: JSON.stringify({ name, parentId, deferStats })
        });
        if (res.status === 429 && attempt < 5) {
          await wait(getRetryDelay(res, attempt));
          return createFolderOnServer(name, parentId, { deferStats, attempt: attempt + 1 });
        }
        if (!res.ok) {
          const err = await res.json().catch(() => ({}));
          throw new Error(err.error || 'Failed to create directory');
        }
        const data = await res.json();
        return data.folder.id;
      }

      async function refreshSharedUploadStats(attempt = 1) {
        const res = await fetch('/share/<%= token %>/upload/refresh-stats', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json'
          },
          body: JSON.stringify({})
        });
        if (res.status === 429 && attempt < 5) {
          await wait(getRetryDelay(res, attempt));
          return refreshSharedUploadStats(attempt + 1);
        }
        if (!res.ok) {
          const err = await res.json().catch(() => ({}));
          throw new Error(err.error || 'Failed to refresh upload totals');
        }
      }

      function showModalAlert(message, title = 'Notification') {
        return new Promise((resolve) => {
          const backdrop = document.getElementById('custom-alert-backdrop');
          const alertBox = document.getElementById('custom-alert-box');
          const titleEl = document.getElementById('custom-alert-title');
          const msgEl = document.getElementById('custom-alert-message');
          const cancelBtn = document.getElementById('custom-alert-cancel-btn');
          const okBtn = document.getElementById('custom-alert-ok-btn');
          const inputContainer = document.getElementById('custom-alert-input-container');

          if (!backdrop || !alertBox) {
            alert(message);
            resolve();
            return;
          }

          msgEl.textContent = message;
          titleEl.textContent = title;
          if (cancelBtn) cancelBtn.classList.add('hidden');
          if (inputContainer) inputContainer.classList.add('hidden');

          backdrop.classList.remove('pointer-events-none');
          backdrop.classList.add('opacity-100');
          alertBox.classList.remove('scale-95', 'opacity-0');
          alertBox.classList.add('scale-100', 'opacity-100');

          const onOk = () => {
            alertBox.classList.remove('scale-100', 'opacity-100');
            alertBox.classList.add('scale-95', 'opacity-0');
            backdrop.classList.remove('opacity-100');
            backdrop.classList.add('pointer-events-none');
            okBtn.removeEventListener('click', onOk);
            resolve();
          };

          okBtn.addEventListener('click', onOk);
        });
      }


      // Upload widget logic
      const widget = document.getElementById('upload-progress-modal');
      const widgetTitle = document.getElementById('upload-progress-text');
      const widgetDetails = document.getElementById('upload-progress-details');
      const widgetProgressBar = document.getElementById('upload-progress-bar');
      const widgetFilesList = document.getElementById('upload-queue-list');
      const widgetToggleBtn = document.getElementById('upload-progress-toggle-btn');
      const widgetCloseBtn = document.getElementById('upload-progress-close-btn');
      const widgetBody = document.getElementById('upload-progress-body');
      const maxRenderedUploadRows = 250;
      
      let isCollapsed = false;
      if (widgetToggleBtn && widgetBody) {
        widgetToggleBtn.addEventListener('click', (e) => {
          e.stopPropagation();
          isCollapsed = !isCollapsed;
          if (isCollapsed) {
            widgetBody.classList.add('hidden');
            widgetToggleBtn.innerHTML = '<i class="bi bi-chevron-up text-base"></i>';
          } else {
            widgetBody.classList.remove('hidden');
            widgetToggleBtn.innerHTML = '<i class="bi bi-chevron-down text-base"></i>';
          }
        });
      }

      if (widgetCloseBtn) {
        widgetCloseBtn.addEventListener('click', (e) => {
          e.stopPropagation();
          widget.classList.add('hidden');
        });
      }

      async function uploadFiles(filesList) {
        if (filesList.length === 0) return;
        
        // Reset and show widget
        widgetFilesList.innerHTML = '';
        widgetTitle.textContent = 'Preparing upload...';
        widgetDetails.textContent = `0% - Uploading 0 of ${filesList.length}`;
        widgetProgressBar.style.width = '0%';
        widget.classList.remove('hidden');
        // Trigger reflow for animations
        widget.offsetHeight;
        widget.classList.remove('translate-y-10', 'opacity-0');
        widget.classList.add('translate-y-0', 'opacity-100');
        
        // Step 1: Detect and sort directories
        const seenDirs = new Set();
        filesList.forEach(file => {
          const relativePath = getFileRelativePath(file);
          const parts = relativePath.split('/');
          let currentPath = '';
          for (let i = 0; i < parts.length - 1; i++) {
            const dirName = parts[i];
            currentPath = currentPath ? `${currentPath}/${dirName}` : dirName;
            if (!seenDirs.has(currentPath)) {
              seenDirs.add(currentPath);
            }
          }
        });

        const sortedDirs = Array.from(seenDirs).sort((a, b) => a.split('/').length - b.split('/').length || a.localeCompare(b));
        const isBulkUpload = filesList.length + sortedDirs.length > 1;

        const pathFolderIdMap = {
          '': '<%= folder ? folder.id : "" %>'
        };

        try {
          // Step 2: Recreate folder structure recursively on server
          for (let i = 0; i < sortedDirs.length; i++) {
            const dirPath = sortedDirs[i];
            const parts = dirPath.split('/');
            const dirName = parts[parts.length - 1];
            const parentPath = parts.slice(0, -1).join('/');
            const parentFolderId = pathFolderIdMap[parentPath] || '<%= folder ? folder.id : "" %>';

            widgetTitle.textContent = `Creating folder ${i + 1} of ${sortedDirs.length}...`;
            const folderId = await createFolderOnServer(dirName, parentFolderId, { deferStats: isBulkUpload });
            pathFolderIdMap[dirPath] = folderId;
          }
        } catch (err) {
          console.error(err);
          // Show alert using custom modal
          await showModalAlert(`Folder creation failed: ${err.message}`, 'Upload Failed');
          widget.classList.add('hidden');
          return;
        }

        // Step 3: Initialize list items
        widgetTitle.textContent = `Uploading ${filesList.length} item${filesList.length === 1 ? '' : 's'}...`;
        const fileElements = filesList.map((file, index) => {
          if (index >= maxRenderedUploadRows) return null;

          const div = document.createElement('div');
          div.className = 'flex flex-col gap-1 pb-1.5 border-b border-gray-100 last:border-0 last:pb-0';
          div.innerHTML = `
            <div class="flex items-center justify-between gap-3 text-xs">
              <span class="font-medium text-gray-700 truncate flex-1" title="${file.name}">${file.name}</span>
              <span class="text-gray-400 font-semibold shrink-0" id="progress-percent-${index}">0%</span>
            </div>
            <div class="w-full bg-gray-100 rounded-full h-1 overflow-hidden">
              <div id="progress-bar-${index}" class="bg-brand-teal h-full w-0 transition-all duration-150 rounded-full"></div>
            </div>
          `;
          widgetFilesList.appendChild(div);
          return {
            percentText: div.querySelector(`#progress-percent-${index}`),
            progressBar: div.querySelector(`#progress-bar-${index}`)
          };
        });

        const hiddenUploadCount = filesList.length - maxRenderedUploadRows;
        if (hiddenUploadCount > 0) {
          const summaryDiv = document.createElement('div');
          summaryDiv.className = 'text-xs font-semibold text-gray-500 bg-gray-50 rounded-lg px-3 py-2 border border-gray-100';
          summaryDiv.textContent = `${hiddenUploadCount} more file${hiddenUploadCount === 1 ? '' : 's'} will upload in the background`;
          widgetFilesList.appendChild(summaryDiv);
        }

        // Step 4: Upload all files sequentially, placing them inside their respective directories
        let successCount = 0;
        const fileProgresses = new Array(filesList.length).fill(0);

        for (let i = 0; i < filesList.length; i++) {
          const file = filesList[i];
          const els = fileElements[i];
          
          const relativePath = getFileRelativePath(file);
          const parentPath = relativePath.split('/').slice(0, -1).join('/');
          const targetFolderId = pathFolderIdMap[parentPath] || '<%= folder ? folder.id : "" %>';

          try {
            await uploadSingleFile(file, targetFolderId, (percent) => {
              if (els) {
                els.percentText.textContent = `${percent}%`;
                els.progressBar.style.width = `${percent}%`;
              }
              fileProgresses[i] = percent;

              const totalPercent = Math.round(fileProgresses.reduce((sum, p) => sum + p, 0) / filesList.length);
              widgetProgressBar.style.width = `${totalPercent}%`;
              widgetDetails.textContent = `${totalPercent}% - Uploading ${successCount + 1} of ${filesList.length}`;
            }, { deferStats: isBulkUpload });
            successCount++;
            fileProgresses[i] = 100;
            const totalPercent = Math.round(fileProgresses.reduce((sum, p) => sum + p, 0) / filesList.length);
            widgetProgressBar.style.width = `${totalPercent}%`;
            widgetDetails.textContent = `${totalPercent}% - Uploaded ${successCount} of ${filesList.length}`;

            if (els) {
              els.percentText.textContent = 'Done';
              els.percentText.classList.remove('text-gray-400');
              els.percentText.classList.add('text-brand-teal');
              els.progressBar.classList.remove('bg-brand-teal');
              els.progressBar.classList.add('bg-green-500');
            }
          } catch (err) {
            console.error(err);
            fileProgresses[i] = 100; // Treat as finalized for total bar calculations
            const totalPercent = Math.round(fileProgresses.reduce((sum, p) => sum + p, 0) / filesList.length);
            widgetProgressBar.style.width = `${totalPercent}%`;

            if (els) {
              els.percentText.textContent = 'Failed';
              els.percentText.classList.remove('text-gray-400');
              els.percentText.classList.add('text-red-500');
              els.progressBar.classList.remove('bg-brand-teal');
              els.progressBar.classList.add('bg-red-500');
              els.progressBar.style.width = '100%';
            }
          }
        }

        if (isBulkUpload) {
          widgetTitle.textContent = 'Finalizing upload totals...';
          widgetDetails.textContent = 'Updating storage usage';
          await refreshSharedUploadStats().catch(err => {
            console.warn('Shared upload totals refresh failed:', err);
          });
        }
        
        widgetTitle.textContent = `Upload finished`;
        widgetDetails.textContent = `Completed ${successCount} of ${filesList.length} files`;
        setTimeout(() => {
          window.location.reload();
        }, 1200);
      }
    <% } %>
  });
</script>

<%- include('../partials/footer') %>
