<%- include('../partials/header') %>

<div class="share-page flex-1 flex flex-col">
  <header class="share-topbar select-none">
    <div class="flex items-center gap-3 min-w-0">
      <img src="/web-app-manifest-512x512.png" alt="Harbor Drive" class="h-10 w-10 rounded-lg shadow-sm object-cover shrink-0">
      <span class="text-lg sm:text-xl font-bold tracking-tight text-brand-dark-grey truncate">
        Harbor <span class="text-brand-teal font-medium">Drive</span>
      </span>
    </div>
    <span class="share-pill hidden sm:inline-flex">
      <i class="bi bi-lock text-brand-teal"></i>
      Protected link
    </span>
  </header>

  <main class="share-main flex-1 flex items-center justify-center">
    <section class="share-auth-panel animate-fade-up select-none">
      <div class="flex items-start gap-4 mb-6">
        <div class="share-icon-box share-icon-box--secure animate-pulse-teal hover-shake">
          <i class="bi bi-shield-lock text-3xl text-brand-teal"></i>
        </div>
        <div class="min-w-0">
          <h1 class="text-xl font-bold tracking-tight text-gray-800">Enter link password</h1>
          <p class="text-sm text-gray-500 mt-1">The owner protected this shared item. Enter the password to continue.</p>
        </div>
      </div>

      <% if (locals.error) { %>
        <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg relative mb-5 text-sm" role="alert">
          <span class="font-semibold"><%= error %></span>
        </div>
      <% } %>

      <form action="/share/<%= token %>/password" method="POST" class="flex flex-col gap-4 text-sm">
        <div>
          <label for="password" class="block font-semibold text-gray-700 mb-1">Password</label>
          <div class="password-container-relative mt-1">
            <input
              type="password"
              id="password"
              name="password"
              required
              placeholder="Enter password"
              class="w-full border border-gray-300 rounded-lg p-2.5 outline-none focus:border-brand-teal text-sm transition"
              autofocus
            >
            <button type="button" class="password-toggle" data-target="password" aria-label="Show password" aria-pressed="false">
              <i class="bi bi-eye"></i>
            </button>
          </div>
        </div>

        <button type="submit" class="w-full inline-flex items-center justify-center gap-2 bg-brand-teal text-white py-3 rounded-lg font-bold hover:bg-brand-teal-dark active:scale-[0.98] transition duration-200 mt-2">
          <i class="bi bi-unlock"></i>
          <span>Unlock shared item</span>
        </button>
      </form>
    </section>
  </main>
</div>

<%- include('../partials/footer') %>
