<%- include('../partials/header') %>

<div class="flex-1 flex items-center justify-center p-4">
  <div class="auth-card w-full max-w-md p-6 sm:p-8 bg-white border border-gray-100 shadow-xl rounded-2xl select-none">

    <div class="flex flex-col items-center gap-2 mb-8">
      <img src="/web-app-manifest-512x512.png" alt="Harbor Drive" class="h-16 w-16 rounded-2xl shadow-md object-cover">
      <h2 class="text-xl font-bold tracking-tight text-gray-800 mt-2">
        Password Protected Link
      </h2>
      <p class="text-xs text-gray-400">Enter the password to access this shared resource</p>
    </div>

    <% if (locals.error) { %>
      <div class="bg-red-50 border-l-4 border-brand-orange text-red-700 px-4 py-3 rounded-lg relative mb-6 text-sm" role="alert">
        <span><%= error %></span>
      </div>
    <% } %>

    <form action="/share/<%= token %>/password" method="POST" class="flex flex-col gap-4 text-sm">
      <div>
        <label for="password" class="block font-semibold text-gray-700 mb-1">Password</label>
        <input 
          type="password" 
          id="password" 
          name="password" 
          required 
          placeholder="••••••••"
          class="w-full border border-gray-300 rounded-lg p-2.5 outline-none focus:border-brand-teal text-sm transition"
        >
      </div>

      <button 
        type="submit" 
        class="w-full bg-brand-teal text-white py-3 rounded-lg font-bold shadow-md hover:bg-brand-teal-dark active:scale-[0.98] transition duration-200 mt-2"
      >
        Unlock Link
      </button>
    </form>

  </div>
</div>

<%- include('../partials/footer') %>
