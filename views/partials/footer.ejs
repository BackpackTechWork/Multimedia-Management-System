  <% if (locals.tab === 'my-drive' || locals.tab === 'starred' || locals.tab === 'recent' || locals.tab === 'trash' || locals.tab === 'storage' || locals.sessions) { %>
    <script src="/js/drive.js"></script>
    <script src="/js/shortcuts.js"></script>
  <% } else if (locals.type) { %>
    <script src="/js/preview.js"></script>
  <% } else { %>
    <script src="/js/auth.js"></script>
  <% } %>
</body>
</html>
