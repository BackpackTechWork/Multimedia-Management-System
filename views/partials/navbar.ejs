<header class="bg-white border-b border-gray-200 h-16 flex items-center justify-between px-6 sticky top-0 z-40 select-none">
  <div class="flex items-center gap-3">
    <% if (locals.tab || locals.showSidebarToggle) { %>
      <button id="mobile-sidebar-toggle" type="button" class="lg:hidden p-2 -ml-2 rounded-lg text-gray-600 hover:bg-gray-100 hover:text-brand-teal transition" aria-label="Open navigation" aria-controls="drive-sidebar" aria-expanded="false">
        <i class="bi bi-list text-2xl"></i>
      </button>
    <% } %>
    <img src="/web-app-manifest-512x512.png" alt="Harbor Drive" class="h-10 w-10 rounded-lg shadow-sm object-cover">
    <span class="text-xl font-bold tracking-tight text-brand-dark-grey">
      Harbor <span class="text-brand-teal font-medium">Drive</span>
    </span>
  </div>

  <% if (locals.tab === 'my-drive' || locals.tab === 'starred' || locals.tab === 'recent' || locals.tab === 'trash') { %>
    <form action="/" method="GET" class="flex items-center gap-2 bg-gray-100 rounded-lg px-3 py-1.5 w-full max-w-2xl border border-transparent focus-within:bg-white focus-within:border-brand-teal focus-within:shadow-sm transition-all duration-200">
      <input type="hidden" name="tab" value="<%= tab %>">
      <% if (locals.currentFolderId) { %>
        <input type="hidden" name="folderId" value="<%= currentFolderId %>">
      <% } %>
      <i class="bi bi-search text-gray-400 text-lg"></i>
      <input 
        type="text" 
        name="search" 
        placeholder="Search files, folders by name..." 
        value="<%= locals.searchQuery || '' %>"
        class="bg-transparent border-none outline-none w-full text-sm text-gray-700 placeholder-gray-400"
      >
      
      <!-- Hidden inputs for type and sortBy -->
      <input type="hidden" name="type" id="search-type-input" value="<%= locals.fileType || 'all' %>">
      <input type="hidden" name="sortBy" id="search-sortBy-input" value="<%= locals.sortBy || 'date' %>">

      <!-- Custom Dropdown for Type -->
      <div class="relative shrink-0" id="search-type-dropdown">
        <button type="button" class="dropdown-trigger flex items-center gap-1.5 px-2.5 py-1.5 text-xs text-gray-500 hover:text-brand-teal font-semibold rounded-lg hover:bg-gray-200/50 transition cursor-pointer select-none">
          <i class="bi <%= {
            all: 'bi-grid-fill',
            image: 'bi-image',
            pdf: 'bi-file-pdf',
            document: 'bi-file-word',
            excel: 'bi-file-spreadsheet',
            markdown: 'bi-markdown',
            code: 'bi-code-slash',
            audio: 'bi-music-note-beamed',
            video: 'bi-film'
          }[locals.fileType] || 'bi-grid-fill' %> text-gray-400 text-sm"></i>
          <span class="selected-text">
            <%= {
              all: 'All Types',
              image: 'Images',
              pdf: 'PDFs',
              document: 'Documents',
              excel: 'Excel',
              markdown: 'Markdown',
              code: 'Code',
              audio: 'Audio',
              video: 'Video'
            }[locals.fileType] || 'All Types' %>
          </span>
          <i class="bi bi-chevron-down text-[10px] text-gray-400"></i>
        </button>
        <div class="dropdown-menu absolute right-0 mt-2 w-48 bg-white border border-gray-200 rounded-xl shadow-lg p-1 hidden z-50 animate-in fade-in-50 slide-in-from-top-1 duration-100">
          <% [
            { val: 'all', label: 'All Types', icon: 'bi-grid-fill' },
            { val: 'image', label: 'Images', icon: 'bi-image' },
            { val: 'pdf', label: 'PDFs', icon: 'bi-file-pdf' },
            { val: 'document', label: 'Documents', icon: 'bi-file-word' },
            { val: 'excel', label: 'Excel', icon: 'bi-file-spreadsheet' },
            { val: 'markdown', label: 'Markdown', icon: 'bi-markdown' },
            { val: 'code', label: 'Code', icon: 'bi-code-slash' },
            { val: 'audio', label: 'Audio', icon: 'bi-music-note-beamed' },
            { val: 'video', label: 'Video', icon: 'bi-film' }
          ].forEach(item => { %>
            <button type="button" data-value="<%= item.val %>" class="dropdown-item w-full text-left px-3 py-2 text-xs font-semibold rounded-lg flex items-center justify-between transition gap-2 <%= (locals.fileType || 'all') === item.val ? 'bg-brand-teal/5 text-brand-teal' : 'text-gray-700 hover:bg-gray-100 hover:text-brand-teal' %>">
              <span class="flex items-center gap-2">
                <i class="bi <%= item.icon %> <%= (locals.fileType || 'all') === item.val ? 'text-brand-teal' : 'text-gray-400' %> text-sm"></i>
                <%= item.label %>
              </span>
              <% if ((locals.fileType || 'all') === item.val) { %>
                <i class="bi bi-check-lg text-brand-teal text-sm"></i>
              <% } %>
            </button>
          <% }) %>
        </div>
      </div>

      <!-- Vertical Divider -->
      <div class="w-px h-5 bg-gray-300 mx-1 shrink-0"></div>

      <!-- Custom Dropdown for SortBy -->
      <div class="relative shrink-0" id="search-sortBy-dropdown">
        <button type="button" class="dropdown-trigger flex items-center gap-1.5 px-2.5 py-1.5 text-xs text-gray-500 hover:text-brand-teal font-semibold rounded-lg hover:bg-gray-200/50 transition cursor-pointer select-none">
          <i class="bi <%= {
            date: 'bi-calendar-event',
            name: 'bi-sort-alpha-down',
            size: 'bi-database'
          }[locals.sortBy] || 'bi-calendar-event' %> text-gray-400 text-sm"></i>
          <span class="selected-text">
            <%= {
              date: 'Sort by Date',
              name: 'Sort by Name',
              size: 'Sort by Size'
            }[locals.sortBy] || 'Sort by Date' %>
          </span>
          <i class="bi bi-chevron-down text-[10px] text-gray-400"></i>
        </button>
        <div class="dropdown-menu absolute right-0 mt-2 w-44 bg-white border border-gray-200 rounded-xl shadow-lg p-1 hidden z-50 animate-in fade-in-50 slide-in-from-top-1 duration-100">
          <% [
            { val: 'date', label: 'Sort by Date', icon: 'bi-calendar-event' },
            { val: 'name', label: 'Sort by Name', icon: 'bi-sort-alpha-down' },
            { val: 'size', label: 'Sort by Size', icon: 'bi-database' }
          ].forEach(item => { %>
            <button type="button" data-value="<%= item.val %>" class="dropdown-item w-full text-left px-3 py-2 text-xs font-semibold rounded-lg flex items-center justify-between transition gap-2 <%= (locals.sortBy || 'date') === item.val ? 'bg-brand-teal/5 text-brand-teal' : 'text-gray-700 hover:bg-gray-100 hover:text-brand-teal' %>">
              <span class="flex items-center gap-2">
                <i class="bi <%= item.icon %> <%= (locals.sortBy || 'date') === item.val ? 'text-brand-teal' : 'text-gray-400' %> text-sm"></i>
                <%= item.label %>
              </span>
              <% if ((locals.sortBy || 'date') === item.val) { %>
                <i class="bi bi-check-lg text-brand-teal text-sm"></i>
              <% } %>
            </button>
          <% }) %>
        </div>
      </div>

      <button type="submit" class="hidden"></button>
    </form>
  <% } else { %>
    <div></div>
  <% } %>

  <% if (locals.userId) { %>
    <div class="flex items-center gap-4">
      <div class="text-right hidden sm:block">
        <div class="text-sm font-semibold text-gray-700 leading-4"><%= locals.userName %></div>
        <div class="text-xs text-gray-400"><%= locals.userEmail %></div>
      </div>
      <div class="relative">
        <button id="profile-dropdown-btn" class="bg-brand-teal text-white w-9 h-9 rounded-full flex items-center justify-center font-bold shadow-sm focus:outline-none hover:bg-brand-teal-dark transition">
          <%= locals.userName.charAt(0).toUpperCase() %>
        </button>
        <div id="profile-dropdown-menu" class="absolute right-0 mt-2 w-48 bg-white border border-gray-200 rounded-lg shadow-lg py-1 hidden z-50">
          <a href="/" class="block px-4 py-2 text-sm text-gray-700 hover:bg-gray-100 flex items-center gap-2">
            <i class="bi bi-hdd-fill text-brand-teal"></i> My Drive
          </a>
          <a href="/auth/profile" class="block px-4 py-2 text-sm text-gray-700 hover:bg-gray-100 flex items-center gap-2">
            <i class="bi bi-person text-brand-teal"></i> Profile
          </a>
          <a href="/auth/devices" class="block px-4 py-2 text-sm text-gray-700 hover:bg-gray-100 flex items-center gap-2">
            <i class="bi bi-laptop text-brand-teal"></i> Active Devices
          </a>
          <% if (locals.isSuperAdmin) { %>
            <a href="/admin/users" class="block px-4 py-2 text-sm text-gray-700 hover:bg-gray-100 flex items-center gap-2">
              <i class="bi bi-people-fill text-brand-teal"></i> Manage Users
            </a>
          <% } %>
          <div class="border-t border-gray-100 my-1"></div>
          <a href="/auth/logout" class="block px-4 py-2 text-sm text-red-600 hover:bg-red-50 flex items-center gap-2">
            <i class="bi bi-box-arrow-right"></i> Sign Out
          </a>
        </div>
      </div>
    </div>
  <% } %>
</header>
