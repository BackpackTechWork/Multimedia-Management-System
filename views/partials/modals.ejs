<!-- MODALS FOR GOOGLE DRIVE OPERATIONS -->

<!-- 1. New Folder Modal -->
<div id="new-folder-modal" class="fixed inset-0 bg-black bg-opacity-40 flex items-center justify-center hidden z-50">
  <div class="bg-white rounded-xl shadow-lg w-full max-w-md p-6 mx-4">
    <h3 class="text-lg font-bold text-gray-800 mb-4">New Folder</h3>
    <input type="text" id="new-folder-name" placeholder="Untitled Folder" class="w-full border border-gray-300 rounded-lg p-2 mb-4 outline-none focus:border-brand-teal text-sm">
    <div class="flex justify-end gap-3">
      <button id="new-folder-cancel-btn" class="px-4 py-2 border border-gray-200 rounded-lg text-sm font-semibold text-gray-500 hover:bg-gray-50">Cancel</button>
      <button id="create-folder-btn" class="px-4 py-2 bg-brand-teal text-white rounded-lg text-sm font-semibold hover:bg-brand-teal-dark">Create</button>
    </div>
  </div>
</div>

<!-- 2. Rename Modal -->
<div id="rename-modal" class="fixed inset-0 bg-black bg-opacity-40 flex items-center justify-center hidden z-50">
  <div class="bg-white rounded-xl shadow-lg w-full max-w-md p-6 mx-4">
    <h3 class="text-lg font-bold text-gray-800 mb-4">Rename</h3>
    <input type="text" id="rename-input" class="w-full border border-gray-300 rounded-lg p-2 mb-4 outline-none focus:border-brand-teal text-sm">
    <div class="flex justify-end gap-3">
      <button id="rename-cancel-btn" class="px-4 py-2 border border-gray-200 rounded-lg text-sm font-semibold text-gray-500 hover:bg-gray-50">Cancel</button>
      <button id="rename-submit-btn" class="px-4 py-2 bg-brand-teal text-white rounded-lg text-sm font-semibold hover:bg-brand-teal-dark">OK</button>
    </div>
  </div>
</div>

<!-- 3. Move / Copy Selection Modal -->
<div id="move-copy-modal" class="fixed inset-0 bg-black bg-opacity-40 flex items-center justify-center hidden z-50">
  <div class="bg-white rounded-xl shadow-lg w-full max-w-lg p-6 mx-4">
    <h3 id="move-copy-title" class="text-lg font-bold text-gray-800 mb-4">Choose Destination</h3>
    <div class="border border-gray-200 rounded-lg p-3 max-h-60 overflow-y-auto mb-4 text-sm">
      <!-- Folder select tree -->
      <div class="flex flex-col gap-1">
        <label class="flex items-center gap-2 p-1.5 rounded hover:bg-gray-50 cursor-pointer">
          <input type="radio" name="dest-folder" value="" checked class="text-brand-teal focus:ring-brand-teal">
          <i class="bi bi-hdd-fill text-gray-400"></i>
          <span>My Drive (Root)</span>
        </label>
        <% if (locals.allUserFolders && allUserFolders.length > 0) { %>
          <% allUserFolders.forEach(folder => { %>
            <label class="flex items-center gap-2 p-1.5 rounded hover:bg-gray-50 cursor-pointer" style="margin-left: <%= (folder.path.split('/').length - 3) * 16 %>px">
              <input type="radio" name="dest-folder" value="<%= folder.id %>" class="text-brand-teal focus:ring-brand-teal">
              <i class="bi bi-folder-fill text-yellow-500"></i>
              <span class="truncate"><%= folder.name %></span>
            </label>
          <% }) %>
        <% } %>
      </div>
    </div>
    <div class="flex justify-end gap-3">
      <button id="move-copy-cancel-btn" class="px-4 py-2 border border-gray-200 rounded-lg text-sm font-semibold text-gray-500 hover:bg-gray-50">Cancel</button>
      <button id="move-copy-submit-btn" class="px-4 py-2 bg-brand-teal text-white rounded-lg text-sm font-semibold hover:bg-brand-teal-dark">Confirm</button>
    </div>
  </div>
</div>

<!-- 4. Share Links Configuration Modal -->
<div id="share-modal" class="fixed inset-0 bg-slate-950 bg-opacity-40 flex items-start sm:items-center justify-center hidden z-50 p-4 overflow-y-auto">
  <div class="share-dialog">
    <div class="share-dialog__header">
      <div class="flex items-center gap-3 min-w-0">
        <span class="share-dialog__icon">
          <i class="bi bi-share"></i>
        </span>
        <div class="min-w-0">
          <h3 class="text-lg font-bold text-gray-800">Share item</h3>
          <p class="text-sm text-gray-500 mt-0.5">Choose who can open this item and what the link allows.</p>
        </div>
      </div>
      <button id="share-close-btn" class="share-dialog__close" title="Close share settings" aria-label="Close share settings">
        <i class="bi bi-x-lg"></i>
      </button>
    </div>

    <div class="share-dialog__body text-sm">
      <section class="share-dialog__section">
        <div class="share-dialog__section-title">
          <div>
            <label for="share-user-search" class="block font-bold text-gray-800">People with access</label>
            <p class="text-xs text-gray-500 mt-0.5">Add existing Harbor Drive accounts.</p>
          </div>
        </div>
        <div id="share-people-picker" class="share-people-picker relative">
          <div id="share-selected-users" class="share-selected-users"></div>
          <input type="text" id="share-user-search" autocomplete="off" placeholder="Search people by name or email" class="share-user-search">
          <div id="share-user-dropdown" class="share-user-dropdown hidden"></div>
        </div>
        <input type="hidden" id="share-recipients">
      </section>

      <section class="share-dialog__section share-dialog__section--tinted">
        <div class="flex items-start gap-3">
          <span class="share-dialog__mini-icon">
            <i class="bi bi-link-45deg"></i>
          </span>
          <div class="min-w-0 flex-1">
            <p class="font-bold text-gray-800">General access</p>
            <p id="share-link-access-help" class="text-xs text-gray-500 mt-0.5 mb-3">Only selected people can open the link.</p>
            <div class="share-dialog__option-grid">
              <label class="share-dialog__field">
                <span>Link access</span>
                <select id="share-link-access">
                  <option value="restricted" selected>Restricted</option>
                  <option value="anyone">Anyone with the link</option>
                </select>
              </label>
              <label class="share-dialog__field">
                <span>Role</span>
                <select id="share-link-role">
                  <option value="viewer" selected>Viewer</option>
                  <option value="editor">Editor</option>
                </select>
              </label>
            </div>
          </div>
        </div>
      </section>

      <section class="share-dialog__section">
        <div class="share-dialog__section-title">
          <div>
            <p class="font-bold text-gray-800">Options</p>
            <p class="text-xs text-gray-500 mt-0.5">Password and expiry are optional.</p>
          </div>
        </div>
        <div class="share-dialog__option-grid">
          <label class="share-dialog__field">
            <span>Password protection</span>
            <input type="password" id="share-password" placeholder="Leave empty for no password">
          </label>
          <label class="share-dialog__field">
            <span>Expiration date</span>
            <input type="datetime-local" id="share-expiry">
          </label>
        </div>
        <label id="share-password-remove-row" class="share-dialog__password-remove hidden">
          <input type="checkbox" id="share-remove-password">
          <span class="share-dialog__toggle-box"><i class="bi bi-check-lg"></i></span>
          <span>
            <strong>Remove existing password</strong>
            <small>The shared link will open without the current password.</small>
          </span>
        </label>
        <label class="share-dialog__toggle">
          <input type="checkbox" id="share-allow-download" checked>
          <span class="share-dialog__toggle-box"><i class="bi bi-check-lg"></i></span>
          <span>
            <strong>Allow downloads</strong>
            <small>Viewers can download files from this link.</small>
          </span>
        </label>
      </section>

      <section id="share-link-container" class="share-dialog__link hidden">
        <div class="flex items-center justify-between gap-3 mb-2">
          <label for="share-link-input" class="text-xs font-bold uppercase tracking-wide text-gray-500">Share link</label>
          <span class="text-xs font-semibold text-brand-teal">One active link per item</span>
        </div>
        <div class="flex gap-2">
          <input type="text" id="share-link-input" readonly class="share-dialog__link-input">
          <button id="copy-share-link-btn" class="share-dialog__copy-btn">
            <i class="bi bi-copy"></i>
            <span>Copy</span>
          </button>
        </div>
      </section>
    </div>

    <div class="share-dialog__footer">
      <button id="revoke-share-btn" class="share-dialog__danger hidden">
        <i class="bi bi-link-45deg"></i>
        <span>Disable link</span>
      </button>
      <button id="generate-share-btn" class="share-dialog__primary">
        <i class="bi bi-check2"></i>
        <span>Save share</span>
      </button>
    </div>
  </div>
</div>

<script type="application/json" id="share-users-data"><%- JSON.stringify(locals.shareUsers || []).replace(/</g, '\\u003c') %></script>

<!-- 5. Version History Modal -->
<div id="versions-modal" class="fixed inset-0 bg-black bg-opacity-40 flex items-center justify-center hidden z-50">
  <div class="bg-white rounded-xl shadow-lg w-full max-w-2xl p-6 mx-4">
    <h3 class="text-lg font-bold text-gray-800 mb-2 flex items-center gap-2">
      <i class="bi bi-clock-history text-brand-teal"></i> Version History
    </h3>
    <p class="text-xs text-gray-400 mb-4">View or restore older versions. You can also upload a newer version slice to keep tracking.</p>

    <!-- Upload new version selector -->
    <div class="mb-4 bg-gray-50 border border-dashed border-gray-300 rounded-lg p-4 flex flex-col items-center justify-center">
      <button onclick="document.getElementById('version-upload-input').click()" class="bg-brand-teal text-white px-4 py-2 rounded-lg text-xs font-semibold hover:bg-brand-teal-dark transition">
        Upload New Version
      </button>
      <input type="file" id="version-upload-input" class="hidden">
    </div>

    <!-- Versions Listing -->
    <div class="border border-gray-100 rounded-lg overflow-hidden mb-4 text-sm max-h-60 overflow-y-auto">
      <table class="w-full text-left border-collapse">
        <thead>
          <tr class="bg-gray-50 text-xs font-bold text-gray-400 uppercase border-b border-gray-100 select-none">
            <th class="p-3">Ver #</th>
            <th class="p-3">Size</th>
            <th class="p-3">Modified</th>
            <th class="p-3 text-right">Actions</th>
          </tr>
        </thead>
        <tbody id="versions-list-body">
          <!-- Populated dynamically -->
        </tbody>
      </table>
    </div>

    <div class="flex justify-end">
      <button id="versions-close-btn" class="px-4 py-2 border border-gray-200 rounded-lg text-sm font-semibold text-gray-500 hover:bg-gray-50">Close</button>
    </div>
  </div>
</div>

<!-- 6. Sticky Upload Queue -->
<div id="upload-progress-modal" class="fixed bottom-4 right-4 md:right-4 left-4 md:left-auto bg-white border border-gray-200 shadow-xl rounded-xl w-[calc(100%-2rem)] md:w-[28rem] hidden z-50 select-none mx-4 md:mx-0 overflow-hidden">
  <div class="flex items-center justify-between px-4 py-3 border-b border-gray-100">
    <div class="min-w-0">
      <span id="upload-progress-text" class="block text-sm font-bold text-gray-800 truncate">Preparing upload...</span>
      <span id="upload-progress-details" class="block text-[11px] text-gray-500 mt-0.5">0% - Calculating time left</span>
    </div>
    <div class="flex items-center">
      <button id="upload-progress-pause-btn" class="p-2 text-gray-500 hover:text-gray-800 hover:bg-gray-100 rounded-md transition" title="Pause upload" aria-label="Pause upload">
        <i class="bi bi-pause-fill text-lg"></i>
      </button>
      <button id="upload-progress-toggle-btn" class="p-2 text-gray-500 hover:text-gray-800 hover:bg-gray-100 rounded-md transition" title="Collapse upload list">
        <i class="bi bi-chevron-down text-base"></i>
      </button>
      <button id="upload-progress-close-btn" class="p-2 -mr-2 text-gray-500 hover:text-gray-800 hover:bg-gray-100 rounded-md transition" title="Cancel upload">
        <i class="bi bi-x-lg text-base"></i>
      </button>
    </div>
  </div>
  <div id="upload-progress-body">
    <div class="h-1 bg-gray-100 overflow-hidden">
      <div id="upload-progress-bar" class="bg-brand-teal h-1 transition-[width] duration-150 ease-out" style="width: 0%"></div>
    </div>
    <div id="upload-queue-list" class="max-h-72 overflow-y-auto py-1">
      <!-- Populated by drive.js -->
    </div>
  </div>
</div>

<!-- Drag Target Overlay overlay -->
<div id="drag-overlay" class="drag-target-overlay">
  <i class="bi bi-cloud-arrow-up-fill text-6xl mb-4 animate-bounce"></i>
  <span class="text-2xl font-bold">Drop files here to upload</span>
  <span class="text-sm text-brand-light-grey mt-1">Files are sliced and uploaded securely</span>
</div>

<!-- Global Modals JavaScript integration -->
<script>
  document.addEventListener('DOMContentLoaded', () => {
    const csrfToken = document.querySelector('meta[name="csrf-token"]')?.getAttribute('content');
    
    // --- MODAL CLOSE & CANCEL ACTIONS (PROGRAMMATIC AND BACKDROP CLICKS) ---
    const closeButtons = [
      { btnId: 'new-folder-cancel-btn', modalId: 'new-folder-modal' },
      { btnId: 'rename-cancel-btn', modalId: 'rename-modal' },
      { btnId: 'move-copy-cancel-btn', modalId: 'move-copy-modal' },
      { btnId: 'share-close-btn', modalId: 'share-modal' },
      { btnId: 'versions-close-btn', modalId: 'versions-modal' },
      { btnId: 'upload-progress-close-btn', modalId: 'upload-progress-modal' }
    ];

    closeButtons.forEach(({ btnId, modalId }) => {
      const btn = document.getElementById(btnId);
      const modal = document.getElementById(modalId);
      if (btn && modal) {
        btn.addEventListener('click', (e) => {
          e.stopPropagation();
          modal.classList.add('hidden');
        });
      }
    });

    const backdropModals = [
      document.getElementById('new-folder-modal'),
      document.getElementById('rename-modal'),
      document.getElementById('move-copy-modal'),
      document.getElementById('share-modal'),
      document.getElementById('versions-modal')
    ];

    backdropModals.forEach(modal => {
      if (modal) {
        modal.addEventListener('click', (e) => {
          // Keep the drive's document-level click handler from clearing the
          // selection while a modal action is in progress.
          e.stopPropagation();
          if (e.target === modal) {
            modal.classList.add('hidden');
          }
        });
      }
    });

    // --- CREATE FOLDER MODAL WORK ---
    const createBtn = document.getElementById('create-folder-btn');
    if (createBtn) {
      createBtn.addEventListener('click', () => {
        const nameInput = document.getElementById('new-folder-name');
        const folderName = nameInput.value;
        const parentId = window.getCurrentFolderId ? window.getCurrentFolderId() : '';

        if (!folderName || folderName.trim() === '') {
          alert('Name is required');
          return;
        }

        fetch('/api/folders', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'x-csrf-token': csrfToken
          },
          body: JSON.stringify({ name: folderName, parentId })
        })
        .then(res => res.json())
        .then(data => {
          if (data.error) alert(data.error);
          else window.location.reload();
        });
      });
    }

    // --- RENAME MODAL SUBMIT WORK ---
    const renameSubmitBtn = document.getElementById('rename-submit-btn');
    if (renameSubmitBtn) {
      renameSubmitBtn.addEventListener('click', () => {
        const selected = window.selectedItems ? window.selectedItems()[0] : null;
        if (!selected) return;

        const input = document.getElementById('rename-input');
        const newName = input.value;
        const id = selected.dataset.id;
        const type = selected.dataset.type;

        if (!newName || newName.trim() === '') {
          alert('Name is required');
          return;
        }

        fetch(`/api/${type}s/rename`, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'x-csrf-token': csrfToken
          },
          body: JSON.stringify({ id, name: newName })
        })
        .then(res => {
          if (res.ok) window.location.reload();
          else alert('Rename action failed');
        });
      });
    }

    // --- MOVE/COPY SELECTION SUBMIT WORK ---
    const moveCopySubmitBtn = document.getElementById('move-copy-submit-btn');
    if (moveCopySubmitBtn) {
      moveCopySubmitBtn.addEventListener('click', async (e) => {
        e.stopPropagation();
        const selected = window.selectedItems ? window.selectedItems() : [];
        if (selected.length === 0) {
          alert('Select at least one item first.');
          return;
        }

        const isCopy = moveCopySubmitBtn.dataset.isCopy === 'true';
        const route = isCopy ? 'copy' : 'move';
        const selectedRadio = document.querySelector('input[name="dest-folder"]:checked');
        const destId = selectedRadio ? selectedRadio.value : '';

        moveCopySubmitBtn.disabled = true;
        const originalText = moveCopySubmitBtn.textContent;
        moveCopySubmitBtn.textContent = isCopy ? 'Copying...' : 'Moving...';

        try {
          await Promise.all(selected.map(async (el) => {
            const type = el.dataset.type;
            const url = `/api/${type}s/${route}`;
            const payload = {
              destinationFolderId: destId
            };

            if (type === 'folder') {
              payload.folderId = el.dataset.id;
            } else {
              payload.fileId = el.dataset.id;
            }

            const res = await fetch(url, {
              method: 'POST',
              headers: {
                'Content-Type': 'application/json',
                'x-csrf-token': csrfToken
              },
              body: JSON.stringify(payload)
            });

            if (!res.ok) {
              const data = await res.json().catch(() => ({}));
              throw new Error(data.error || `Failed to ${route} ${el.dataset.name || type}`);
            }
          }));

          window.location.reload();
        } catch (err) {
          alert(err.message || `${originalText} failed`);
          moveCopySubmitBtn.disabled = false;
          moveCopySubmitBtn.textContent = originalText;
        }
      });
    }

    // --- SHARE CONFIGURATION MODAL ---
    const generateShareBtn = document.getElementById('generate-share-btn');
    const revokeShareBtn = document.getElementById('revoke-share-btn');
    const copyLinkBtn = document.getElementById('copy-share-link-btn');
    const shareUsersDataEl = document.getElementById('share-users-data');
    const shareUserSearch = document.getElementById('share-user-search');
    const shareUserDropdown = document.getElementById('share-user-dropdown');
    const shareSelectedUsers = document.getElementById('share-selected-users');
    const shareRecipientsInput = document.getElementById('share-recipients');
    const shareLinkAccess = document.getElementById('share-link-access');
    const shareLinkRole = document.getElementById('share-link-role');
    const shareLinkAccessHelp = document.getElementById('share-link-access-help');
    const sharePasswordInput = document.getElementById('share-password');
    const shareRemovePasswordInput = document.getElementById('share-remove-password');
    const sharePasswordRemoveRow = document.getElementById('share-password-remove-row');
    let shareUsers = [];
    let selectedShareUsers = [];

    try {
      shareUsers = JSON.parse(shareUsersDataEl?.textContent || '[]');
    } catch {
      shareUsers = [];
    }

    function escapeHtml(value) {
      return String(value ?? '')
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#39;');
    }

    function getUserInitials(user) {
      const name = (user.name || user.email || '').trim();
      if (!name) return 'U';
      return name.split(/\s+/).slice(0, 2).map(part => part[0]).join('').toUpperCase();
    }

    function syncSelectedShareUsers() {
      if (!shareSelectedUsers || !shareRecipientsInput) return;

      shareSelectedUsers.innerHTML = selectedShareUsers.map(user => {
        const label = escapeHtml(user.name || user.email);
        return `
        <span class="share-user-chip">
          <span class="truncate max-w-[12rem]">${label}</span>
          <button type="button" data-remove-share-user="${user.id}" aria-label="Remove ${label}">
            <i class="bi bi-x text-sm"></i>
          </button>
        </span>
      `;
      }).join('');
      shareRecipientsInput.value = selectedShareUsers.map(user => user.id).join(',');
    }

    function renderShareUserDropdown(query = '') {
      if (!shareUserDropdown) return;

      const normalizedQuery = query.trim().toLowerCase();
      const selectedIds = new Set(selectedShareUsers.map(user => Number(user.id)));
      const matches = shareUsers
        .filter(user => !selectedIds.has(Number(user.id)))
        .filter(user => {
          if (!normalizedQuery) return true;
          return `${user.name || ''} ${user.email || ''}`.toLowerCase().includes(normalizedQuery);
        })
        .slice(0, 8);

      if (matches.length === 0) {
        shareUserDropdown.innerHTML = '<div class="px-3 py-2 text-xs text-gray-400">No matching people</div>';
        shareUserDropdown.classList.remove('hidden');
        return;
      }

      shareUserDropdown.innerHTML = matches.map(user => `
        <button type="button" class="share-user-option" data-share-user-id="${user.id}">
          <span class="share-user-option__avatar">${escapeHtml(getUserInitials(user))}</span>
          <span class="share-user-option__meta">
            <span class="block text-sm font-semibold text-gray-700 truncate">${escapeHtml(user.name || user.email)}</span>
            <span class="block text-xs text-gray-400 truncate">${escapeHtml(user.email)}</span>
          </span>
        </button>
      `).join('');
      shareUserDropdown.classList.remove('hidden');
    }

    function resetSharePeoplePicker() {
      selectedShareUsers = [];
      if (shareUserSearch) shareUserSearch.value = '';
      if (shareUserDropdown) shareUserDropdown.classList.add('hidden');
      syncSelectedShareUsers();
    }

    function toDateTimeLocalValue(value) {
      if (!value) return '';
      const date = new Date(value);
      if (Number.isNaN(date.getTime())) return '';
      const offsetMs = date.getTimezoneOffset() * 60000;
      return new Date(date.getTime() - offsetMs).toISOString().slice(0, 16);
    }

    function setSelectedShareUsers(users) {
      const knownUsersById = new Map(shareUsers.map(user => [Number(user.id), user]));
      selectedShareUsers = (users || []).map(user => {
        const known = knownUsersById.get(Number(user.id));
        return known || user;
      });
      syncSelectedShareUsers();
    }

    function updateShareLinkAccessHelp() {
      if (!shareLinkAccessHelp || !shareLinkAccess || !shareLinkRole) return;
      const role = shareLinkRole.value === 'editor' ? 'edit' : 'view';
      shareLinkAccessHelp.textContent = shareLinkAccess.value === 'anyone'
        ? `Anyone with this link can ${role}.`
        : `Only selected people can ${role}.`;
    }

    if (shareUserSearch) {
      shareUserSearch.addEventListener('focus', () => renderShareUserDropdown(shareUserSearch.value));
      shareUserSearch.addEventListener('input', () => renderShareUserDropdown(shareUserSearch.value));
    }

    if (shareUserDropdown) {
      shareUserDropdown.addEventListener('click', (e) => {
        const option = e.target.closest('[data-share-user-id]');
        if (!option) return;

        const user = shareUsers.find(candidate => Number(candidate.id) === Number(option.dataset.shareUserId));
        if (user && !selectedShareUsers.some(candidate => Number(candidate.id) === Number(user.id))) {
          selectedShareUsers.push(user);
          syncSelectedShareUsers();
        }
        if (shareUserSearch) {
          shareUserSearch.value = '';
          shareUserSearch.focus();
        }
        renderShareUserDropdown('');
      });
    }

    if (shareSelectedUsers) {
      shareSelectedUsers.addEventListener('click', (e) => {
        const removeBtn = e.target.closest('[data-remove-share-user]');
        if (!removeBtn) return;
        selectedShareUsers = selectedShareUsers.filter(user => Number(user.id) !== Number(removeBtn.dataset.removeShareUser));
        syncSelectedShareUsers();
        renderShareUserDropdown(shareUserSearch?.value || '');
      });
    }

    [shareLinkAccess, shareLinkRole].forEach(control => {
      if (control) control.addEventListener('change', updateShareLinkAccessHelp);
    });

    document.addEventListener('click', (e) => {
      if (!shareUserDropdown || shareUserDropdown.classList.contains('hidden')) return;
      if (e.target.closest('#share-people-picker')) return;
      shareUserDropdown.classList.add('hidden');
    }, true);

    updateShareLinkAccessHelp();

    if (sharePasswordInput && shareRemovePasswordInput) {
      sharePasswordInput.addEventListener('input', () => {
        if (sharePasswordInput.value.trim() !== '') {
          shareRemovePasswordInput.checked = false;
        }
      });

      shareRemovePasswordInput.addEventListener('change', () => {
        if (shareRemovePasswordInput.checked) {
          sharePasswordInput.value = '';
        }
      });
    }

    if (generateShareBtn) {
      generateShareBtn.addEventListener('click', async (e) => {
        e.stopPropagation();
        const selected = window.selectedItems ? window.selectedItems()[0] : null;
        if (!selected) {
          alert('Select a file or folder first.');
          return;
        }

        const password = sharePasswordInput?.value || '';
        const removePassword = shareRemovePasswordInput?.checked || false;
        const recipientUserIds = selectedShareUsers.map(user => user.id);
        const expiry = document.getElementById('share-expiry').value;
        const allowDownload = document.getElementById('share-allow-download').checked;
        const linkAccess = shareLinkAccess?.value || 'restricted';
        const linkRole = shareLinkRole?.value || 'viewer';
        const id = selected.dataset.id;
        const type = selected.dataset.type;

        const payload = {
          fileId: type === 'file' ? id : null,
          folderId: type === 'folder' ? id : null,
          password,
          removePassword,
          recipientUserIds,
          expiresAt: expiry || null,
          allowDownload,
          linkAccess,
          linkRole
        };

        generateShareBtn.disabled = true;
        generateShareBtn.innerHTML = '<i class="bi bi-arrow-repeat"></i><span>Saving...</span>';

        try {
          const res = await fetch('/share/api/create', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
              'x-csrf-token': csrfToken
            },
            body: JSON.stringify(payload)
          });
          const data = await res.json().catch(() => ({}));

          if (!res.ok) {
            throw new Error(data.error || 'Unable to generate share link');
          }

          const shareLink = `${window.location.origin}/share/${data.token}`;
          document.getElementById('share-link-input').value = shareLink;
          document.getElementById('share-link-container').classList.remove('hidden');
          if (revokeShareBtn) {
            revokeShareBtn.classList.remove('hidden');
            revokeShareBtn.dataset.token = data.token;
          }
        } catch (err) {
          alert(err.message || 'Unable to generate share link');
        } finally {
          generateShareBtn.disabled = false;
          generateShareBtn.innerHTML = '<i class="bi bi-check2"></i><span>Save share</span>';
        }
      });
    }

    if (revokeShareBtn) {
      revokeShareBtn.addEventListener('click', () => {
        const token = revokeShareBtn.dataset.token;
        if (!token) return;

        fetch('/share/api/revoke', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'x-csrf-token': csrfToken
          },
          body: JSON.stringify({ token })
        })
        .then(res => {
          if (res.ok) {
            document.getElementById('share-link-container').classList.add('hidden');
            resetSharePeoplePicker();
            if (sharePasswordInput) sharePasswordInput.value = '';
            if (shareRemovePasswordInput) shareRemovePasswordInput.checked = false;
            if (sharePasswordRemoveRow) sharePasswordRemoveRow.classList.add('hidden');
            document.getElementById('share-expiry').value = '';
            if (shareLinkAccess) shareLinkAccess.value = 'restricted';
            if (shareLinkRole) shareLinkRole.value = 'viewer';
            updateShareLinkAccessHelp();
            revokeShareBtn.classList.add('hidden');
            alert('Sharing link disabled successfully.');
          }
        });
      });
    }

    if (copyLinkBtn) {
      copyLinkBtn.addEventListener('click', () => {
        const link = document.getElementById('share-link-input');
        link.select();
        document.execCommand('copy');
        alert('Sharing link copied to clipboard!');
      });
    }

    async function loadExistingShareSettings(selected) {
      const type = selected.dataset.type;
      const id = selected.dataset.id;
      const params = new URLSearchParams();
      if (type === 'file') params.set('fileId', id);
      else params.set('folderId', id);

      const res = await fetch(`/share/api/settings?${params.toString()}`);
      const data = await res.json().catch(() => ({}));
      if (!res.ok) {
        throw new Error(data.error || 'Unable to load share settings');
      }

      if (!data.exists) return;

      setSelectedShareUsers(data.recipients || []);
      if (shareLinkAccess) shareLinkAccess.value = data.linkAccess === 'anyone' ? 'anyone' : 'restricted';
      if (shareLinkRole) shareLinkRole.value = data.linkRole === 'editor' ? 'editor' : 'viewer';
      const allowDownloadInput = document.getElementById('share-allow-download');
      if (allowDownloadInput) allowDownloadInput.checked = data.allowDownload !== false;
      const expiryInput = document.getElementById('share-expiry');
      if (expiryInput) expiryInput.value = toDateTimeLocalValue(data.expiresAt);
      const passwordInput = document.getElementById('share-password');
      if (passwordInput) {
        passwordInput.value = '';
        passwordInput.placeholder = data.hasPassword ? 'Password is already set. Type a new one to change it.' : 'Leave empty for no password';
      }
      if (shareRemovePasswordInput) shareRemovePasswordInput.checked = false;
      if (sharePasswordRemoveRow) {
        sharePasswordRemoveRow.classList.toggle('hidden', !data.hasPassword);
      }

      const shareLink = `${window.location.origin}/share/${data.token}`;
      document.getElementById('share-link-input').value = shareLink;
      document.getElementById('share-link-container').classList.remove('hidden');
      if (revokeShareBtn) {
        revokeShareBtn.classList.remove('hidden');
        revokeShareBtn.dataset.token = data.token;
      }
      updateShareLinkAccessHelp();
    }

    // --- VERSION HISTORY VIEW ENGINE ---
    const versionsBtn = document.getElementById('detail-versions-btn');
    const versionUploadInput = document.getElementById('version-upload-input');
    
    if (versionsBtn) {
      versionsBtn.addEventListener('click', () => {
        const selected = window.selectedItems ? window.selectedItems()[0] : null;
        if (!selected || selected.dataset.type !== 'file') return;

        // Fetch version history
        fetchVersions(selected.dataset.id);
      });
    }

    function fetchVersions(fileId) {
      const body = document.getElementById('versions-list-body');
      body.innerHTML = '<tr><td colspan="4" class="p-3 text-center text-gray-400">Loading version history...</td></tr>';
      document.getElementById('versions-modal').classList.remove('hidden');

      fetch(`/api/versions?fileId=${fileId}`)
        .then(res => res.json())
        .then(data => {
          if (data.versions && data.versions.length > 0) {
            let html = '';
            data.versions.forEach(v => {
              html += `
                <tr class="border-b border-gray-100">
                  <td class="p-3 font-semibold text-gray-600">Version ${v.versionNumber}</td>
                  <td class="p-3 text-gray-500">${window.formatBytes ? window.formatBytes(v.size) : v.size}</td>
                  <td class="p-3 text-gray-500">${new Date(v.uploadedAt).toLocaleString()}</td>
                  <td class="p-3 text-right">
                    <button onclick="restoreVersion(${v.id})" class="text-brand-teal hover:underline font-semibold mr-3">Restore</button>
                    <button onclick="deleteVersion(${v.id})" class="text-red-500 hover:underline">Delete</button>
                  </td>
                </tr>
              `;
            });
            body.innerHTML = html;
          } else {
            body.innerHTML = '<tr><td colspan="4" class="p-3 text-center text-gray-400">No older versions found.</td></tr>';
          }
        });
    }

    // Restore versions
    window.restoreVersion = async function(versionId) {
      if (!await confirm('Are you sure you want to restore this older version? The current version will be archived.')) return;
      fetch('/api/versions/restore', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'x-csrf-token': csrfToken
        },
        body: JSON.stringify({ versionId })
      })
      .then(res => {
        if (res.ok) window.location.reload();
        else alert('Restoration failed');
      });
    };

    // Delete version
    window.deleteVersion = async function(versionId) {
      if (!await confirm('Permanently delete this version record and storage file?')) return;
      fetch('/api/versions/delete', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'x-csrf-token': csrfToken
        },
        body: JSON.stringify({ versionId })
      })
      .then(res => {
        if (res.ok) {
          const selected = window.selectedItems ? window.selectedItems()[0] : null;
          if (selected) fetchVersions(selected.dataset.id);
        } else {
          alert('Delete version failed');
        }
      });
    };

    // Upload new version slice handler
    if (versionUploadInput) {
      versionUploadInput.addEventListener('change', async (e) => {
        const file = e.target.files[0];
        const selected = window.selectedItems ? window.selectedItems()[0] : null;
        if (!file || !selected) return;

        // Hide version modal, open progress modal
        document.getElementById('versions-modal').classList.add('hidden');
        const progressModal = document.getElementById('upload-progress-modal');
        const progressBar = document.getElementById('upload-progress-bar');
        const progressDetails = document.getElementById('upload-progress-details');
        const progressText = document.getElementById('upload-progress-text');
        
        progressModal.classList.remove('hidden');
        progressText.textContent = `Uploading new version: ${file.name}...`;

        const CHUNK_SIZE = 5 * 1024 * 1024;
        const totalChunks = Math.max(1, Math.ceil(file.size / CHUNK_SIZE));
        const uploadId = window.crypto?.randomUUID
          ? window.crypto.randomUUID()
          : `${Date.now()}-${Math.random().toString(16).slice(2)}`;

        try {
          for (let i = 0; i < totalChunks; i++) {
            const start = i * CHUNK_SIZE;
            const end = Math.min(file.size, start + CHUNK_SIZE);
            const chunkBlob = file.slice(start, end);

            const formData = new FormData();
            formData.append('uploadId', uploadId);
            formData.append('chunkIndex', i);
            formData.append('chunkOffset', start);
            formData.append('fileSize', file.size);
            formData.append('chunk', chunkBlob);

            const chunkRes = await fetch('/api/upload/chunk', {
              method: 'POST',
              headers: { 'x-csrf-token': csrfToken },
              body: formData
            });
            if (!chunkRes.ok) {
              const chunkError = await chunkRes.json().catch(() => ({}));
              throw new Error(chunkError.error || `Chunk ${i + 1} failed`);
            }

            const pct = Math.min(98, Math.round(((i + 1) / totalChunks) * 98));
            progressBar.style.width = `${pct}%`;
            progressDetails.textContent = `${pct}% - Uploading chunk ${i+1} of ${totalChunks}`;
          }

          progressDetails.textContent = 'Archiving current version and merging...';

          // Call new version complete route
          const mergeRes = await fetch('/api/upload/version/complete', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
              'x-csrf-token': csrfToken
            },
            body: JSON.stringify({
              uploadId,
              totalChunks,
              filename: file.name,
              fileSize: file.size,
              fileId: selected.dataset.id
            })
          });

          if (mergeRes.ok) {
            if (window.playNotificationSound) {
              await window.playNotificationSound();
            }
            window.location.reload();
          } else {
            throw new Error('Merge request failed');
          }
        } catch (err) {
          alert(`New version upload failed: ${err.message}`);
          progressModal.classList.add('hidden');
        }
      });
    }

    // Detail actions triggers from selection
    const renameBtn = document.getElementById('detail-rename-btn');
    if (renameBtn) {
      renameBtn.addEventListener('click', () => {
        const selected = window.selectedItems ? window.selectedItems()[0] : null;
        if (!selected) return;
        
        const renameInput = document.getElementById('rename-input');
        renameInput.value = selected.dataset.name;
        document.getElementById('rename-modal').classList.remove('hidden');
      });
    }

    const deleteBtn = document.getElementById('detail-delete-btn');
    if (deleteBtn) {
      deleteBtn.addEventListener('click', () => {
        const selected = window.selectedItems ? window.selectedItems() : [];
        if (selected.length === 0) return;

        if (window.driveContext?.tab === 'trash') {
          if (window.purgeSelected) window.purgeSelected(selected);
          return;
        }

        if (window.moveSelectedToTrash) window.moveSelectedToTrash(selected);
      });
    }

    const starBtn = document.getElementById('detail-star-btn');
    if (starBtn) {
      starBtn.addEventListener('click', () => {
        const selected = window.selectedItems ? window.selectedItems() : [];
        if (selected.length === 0) return;

        selected.forEach(async (el) => {
          const res = await fetch('/api/favorites/toggle', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
              'x-csrf-token': csrfToken
            },
            body: JSON.stringify({ entityId: el.dataset.id, entityType: el.dataset.type })
          });
          const data = await res.json();
          const starIcon = el.querySelector('.starred-icon');
          if (starIcon) {
            if (data.starred) {
              starIcon.className = 'starred-icon bi bi-star-fill text-yellow-500';
            } else {
              starIcon.className = 'starred-icon bi bi-star text-gray-300';
            }
          }
        });
        setTimeout(() => window.location.reload(), 500);
      });
    }

    const moveBtn = document.getElementById('detail-move-btn');
    if (moveBtn) {
      moveBtn.addEventListener('click', (e) => {
        e.stopPropagation();
        const selected = window.selectedItems ? window.selectedItems() : [];
        if (selected.length === 0) {
          alert('Select at least one item first.');
          return;
        }
        document.getElementById('move-copy-title').textContent = 'Move Selection';
        moveCopySubmitBtn.textContent = 'Move';
        moveCopySubmitBtn.dataset.isCopy = 'false';
        document.getElementById('move-copy-modal').classList.remove('hidden');
      });
    }

    const copyBtn = document.getElementById('detail-copy-btn');
    if (copyBtn) {
      copyBtn.addEventListener('click', (e) => {
        e.stopPropagation();
        const selected = window.selectedItems ? window.selectedItems() : [];
        if (selected.length === 0) {
          alert('Select at least one item first.');
          return;
        }
        document.getElementById('move-copy-title').textContent = 'Copy Selection';
        moveCopySubmitBtn.textContent = 'Copy';
        moveCopySubmitBtn.dataset.isCopy = 'true';
        document.getElementById('move-copy-modal').classList.remove('hidden');
      });
    }

    const shareBtn = document.getElementById('detail-share-btn');
    if (shareBtn) {
      shareBtn.addEventListener('click', (e) => {
        e.stopPropagation();
        const selected = window.selectedItems ? window.selectedItems() : [];
        if (selected.length === 0) {
          alert('Select a file or folder first.');
          return;
        }
        if (selected.length > 1) {
          alert('Select only one item to share.');
          return;
        }
        document.getElementById('share-link-container').classList.add('hidden');
        resetSharePeoplePicker();
        if (sharePasswordInput) {
          sharePasswordInput.value = '';
          sharePasswordInput.placeholder = 'Leave empty for no password';
        }
        if (shareRemovePasswordInput) shareRemovePasswordInput.checked = false;
        if (sharePasswordRemoveRow) sharePasswordRemoveRow.classList.add('hidden');
        document.getElementById('share-expiry').value = '';
        if (shareLinkAccess) shareLinkAccess.value = 'restricted';
        if (shareLinkRole) shareLinkRole.value = 'viewer';
        updateShareLinkAccessHelp();
        const allowDownloadInput = document.getElementById('share-allow-download');
        if (allowDownloadInput) allowDownloadInput.checked = true;
        if (revokeShareBtn) {
          revokeShareBtn.classList.add('hidden');
          delete revokeShareBtn.dataset.token;
        }
        document.getElementById('share-modal').classList.remove('hidden');
        loadExistingShareSettings(selected[0]).catch(err => alert(err.message || 'Unable to load share settings'));
      });
    }

    const downloadBtn = document.getElementById('detail-download-btn');
    if (downloadBtn) {
      downloadBtn.addEventListener('click', () => {
        const selected = window.selectedItems ? window.selectedItems() : [];
        selected.forEach(el => {
          const type = el.dataset.type;
          const id = el.dataset.id;
          window.open(`/api/${type}s/download/${id}`, '_blank');
        });
      });
    }
  });
</script>
