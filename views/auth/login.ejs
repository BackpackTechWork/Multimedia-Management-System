<%- include('../partials/header') %>

<div class="flex-1 flex items-center justify-center md:justify-start p-6 sm:p-12 md:pl-20 lg:pl-32 bg-cover bg-center bg-no-repeat" style="background-image: url('/harbor-drive.png');">
  <div class="auth-card w-full max-w-md p-6 sm:p-8 bg-white/95 backdrop-blur-sm border border-white/20 shadow-2xl rounded-2xl select-none">

    <div class="flex flex-col items-center gap-2 mb-8">
      <img src="/web-app-manifest-512x512.png" alt="Harbor Drive" class="h-16 w-16 rounded-2xl shadow-md object-cover">
      <h2 class="text-2xl font-bold tracking-tight text-gray-800 mt-2">
        Welcome to Harbor Drive
      </h2>
      <p class="text-xs text-gray-400">Sign in to manage your files</p>
    </div>

    <div id="alert-container">
      <% if (locals.error) { %>
        <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg relative mb-6 text-sm" role="alert">
          <span><%= error %></span>
        </div>
      <% } %>
      <% if (locals.success) { %>
        <div class="bg-green-50 border border-brand-teal text-green-700 px-4 py-3 rounded-lg relative mb-6 text-sm" role="alert">
          <span><%= success %></span>
        </div>
      <% } %>
    </div>

    <form action="/auth/login" method="POST" class="flex flex-col gap-5 text-sm">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <% if (locals.returnTo) { %>
        <input type="hidden" name="returnTo" value="<%= returnTo %>">
      <% } %>
      
      <div>
        <label for="email" class="block font-semibold text-gray-700 mb-1">Email Address</label>
        <input 
          type="email" 
          id="email" 
          name="email" 
          required 
          placeholder="name@domain.com"
          autocomplete="email"
          class="w-full border border-gray-300 rounded-lg p-2.5 outline-none focus:border-brand-teal text-sm transition"
        >
      </div>

      <div>
        <label for="password" class="block font-semibold text-gray-700 mb-1">Password</label>
        <div class="relative">
          <input 
            type="password" 
            id="password" 
            name="password" 
            required 
            placeholder="Password"
            autocomplete="current-password"
            style="padding-right: 2.75rem;"
            class="w-full border border-gray-300 rounded-lg p-2.5 outline-none focus:border-brand-teal text-sm transition"
          >
          <button type="button" class="password-toggle absolute right-2 top-2.5 p-1 text-gray-500 hover:text-brand-teal" data-target="password" aria-label="Show password" aria-pressed="false">
            <i class="bi bi-eye"></i>
          </button>
        </div>
      </div>

      <div class="flex items-center justify-between mt-1">
        <label class="flex items-center gap-2 text-xs font-semibold text-gray-500 cursor-pointer">
          <input type="checkbox" name="rememberMe" class="rounded text-brand-teal focus:ring-brand-teal border-gray-300">
          <span>Remember login session</span>
        </label>
      </div>

      <button 
        type="submit" 
        class="w-full bg-brand-teal text-white py-3 rounded-lg font-bold shadow-md hover:bg-brand-teal-dark active:scale-[0.98] transition duration-200 mt-2"
      >
        Sign In
      </button>
    </form>

  </div>
</div>

<%- include('../partials/footer') %>
