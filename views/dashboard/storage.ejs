<%- include('../partials/header') %>

<%- include('../partials/navbar') %>

<script>
  window.driveContext = {
    tab: 'storage',
    currentFolderId: ''
  };
</script>

<div class="flex-1 flex overflow-hidden">
  <%- include('../partials/sidebar') %>

  <main class="flex-1 flex flex-col min-w-0 bg-[#F8F9FA] overflow-y-auto">
    <div class="p-6 md:p-8 w-full">
      <div class="flex flex-col gap-6">
        <div class="flex flex-col gap-5 border-b border-gray-200 pb-6">
          <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
            <div>
              <h2 class="text-2xl font-bold text-gray-900 flex items-center gap-2">
                <i class="bi bi-pie-chart-fill text-brand-teal"></i>
                Storage
              </h2>
              <p class="text-sm text-gray-500 mt-1">Review what is using space in Harbor Drive.</p>
            </div>

            <a href="/" class="inline-flex items-center gap-2 text-sm font-semibold text-brand-teal hover:text-brand-teal-dark transition self-start sm:self-auto">
              <i class="bi bi-arrow-left"></i>
              My Drive
            </a>
          </div>

          <form method="GET" action="/storage" class="flex flex-wrap items-center gap-3">
            <label class="inline-flex items-center gap-2 border border-gray-300 bg-white hover:bg-gray-50 rounded-lg px-3 py-2 text-sm font-semibold text-gray-700 transition">
              <span>Type</span>
              <select name="type" class="bg-transparent outline-none cursor-pointer text-sm" onchange="this.form.submit()">
                <option value="all" <%= typeFilter === 'all' ? 'selected' : '' %>>All</option>
                <option value="videos" <%= typeFilter === 'videos' ? 'selected' : '' %>>Videos</option>
                <option value="images" <%= typeFilter === 'images' ? 'selected' : '' %>>Images</option>
                <option value="documents" <%= typeFilter === 'documents' ? 'selected' : '' %>>Documents</option>
                <option value="spreadsheets" <%= typeFilter === 'spreadsheets' ? 'selected' : '' %>>Spreadsheets</option>
                <option value="audio" <%= typeFilter === 'audio' ? 'selected' : '' %>>Audio</option>
                <option value="archives" <%= typeFilter === 'archives' ? 'selected' : '' %>>Archives</option>
                <option value="code" <%= typeFilter === 'code' ? 'selected' : '' %>>Code</option>
                <option value="other" <%= typeFilter === 'other' ? 'selected' : '' %>>Other</option>
              </select>
            </label>

            <label class="inline-flex items-center gap-2 border border-gray-300 bg-white hover:bg-gray-50 rounded-lg px-3 py-2 text-sm font-semibold text-gray-700 transition">
              <span>Modified</span>
              <select name="modified" class="bg-transparent outline-none cursor-pointer text-sm" onchange="this.form.submit()">
                <option value="all" <%= modifiedFilter === 'all' ? 'selected' : '' %>>Any time</option>
                <option value="today" <%= modifiedFilter === 'today' ? 'selected' : '' %>>Today</option>
                <option value="week" <%= modifiedFilter === 'week' ? 'selected' : '' %>>Last 7 days</option>
                <option value="month" <%= modifiedFilter === 'month' ? 'selected' : '' %>>Last 30 days</option>
                <option value="year" <%= modifiedFilter === 'year' ? 'selected' : '' %>>Last year</option>
              </select>
            </label>

            <label class="inline-flex items-center gap-2 border border-gray-300 bg-white hover:bg-gray-50 rounded-lg px-3 py-2 text-sm font-semibold text-gray-700 transition">
              <span>Source</span>
              <select name="source" class="bg-transparent outline-none cursor-pointer text-sm" onchange="this.form.submit()">
                <option value="all" <%= sourceFilter === 'all' ? 'selected' : '' %>>All</option>
                <option value="private" <%= sourceFilter === 'private' ? 'selected' : '' %>>Private</option>
                <option value="public" <%= sourceFilter === 'public' ? 'selected' : '' %>>Public</option>
              </select>
            </label>
          </form>

          <div class="flex flex-col gap-3">
            <div class="flex flex-wrap items-end gap-x-2 gap-y-1">
              <span class="text-4xl font-medium leading-none text-gray-900"><%= formatBytes(storageStats.totalSize) %></span>
              <span class="text-sm text-gray-500 pb-1">used across <%= storageStats.totalFiles || 0 %> files</span>
            </div>

            <div class="h-2 w-full rounded-full bg-gray-100 overflow-hidden flex" aria-label="Storage usage by type">
              <% if (categoryTotals.length > 0) { %>
                <% categoryTotals.forEach(category => { %>
                  <span
                    class="h-full"
                    title="<%= category.name %>: <%= formatBytes(category.size) %>"
                    style="width: <%= Math.max(category.percent, 0.75).toFixed(2) %>%; background-color: <%= category.color %>;"
                  ></span>
                <% }) %>
              <% } %>
            </div>

            <div class="flex flex-wrap gap-x-5 gap-y-2 text-sm text-gray-700">
              <% categoryTotals.forEach(category => { %>
                <span class="inline-flex items-center gap-2">
                  <span class="h-2.5 w-2.5 rounded-full" style="background-color: <%= category.color %>;"></span>
                  <span><%= category.name %></span>
                </span>
              <% }) %>
            </div>
          </div>
        </div>

        <div class="bg-white border border-gray-200 rounded-xl overflow-hidden">
          <div class="grid grid-cols-12 gap-3 px-4 py-3 border-b border-gray-200 text-sm font-semibold text-gray-600">
            <div class="col-span-7 md:col-span-6">Name</div>
            <div class="hidden md:block md:col-span-2">Type</div>
            <div class="hidden sm:block sm:col-span-2">Modified</div>
            <div class="col-span-5 sm:col-span-3 md:col-span-2 text-right flex items-center justify-end gap-2">
              Storage used
              <span class="inline-flex h-7 w-7 items-center justify-center rounded-full bg-blue-100 text-blue-700" aria-hidden="true">
                <i class="bi bi-arrow-down text-base"></i>
              </span>
            </div>
          </div>

          <% if (files.length === 0) { %>
            <div class="px-4 py-16 text-center">
              <div class="mx-auto mb-4 h-14 w-14 rounded-xl bg-gray-100 text-gray-400 flex items-center justify-center">
                <i class="bi bi-hdd text-2xl"></i>
              </div>
              <h3 class="text-base font-bold text-gray-800">No files match these filters</h3>
              <p class="text-sm text-gray-500 mt-1">Change the filters or upload files to see storage usage.</p>
            </div>
          <% } else { %>
            <div class="divide-y divide-gray-200">
              <% files.forEach((file, index) => { %>
                <a
                  href="/preview/<%= file.previewRoute %>/<%= file.id %>"
                  class="grid grid-cols-12 gap-3 px-4 py-4 items-center hover:bg-gray-50 transition text-gray-800 <%= index === 0 ? 'bg-gray-50' : '' %>"
                >
                  <div class="col-span-7 md:col-span-6 min-w-0 flex items-center gap-3">
                    <span class="h-9 w-9 rounded-lg bg-gray-100 flex items-center justify-center shrink-0" style="color: <%= file.categoryColor %>;">
                      <i class="bi <%= file.categoryIcon %> text-lg"></i>
                    </span>
                    <div class="min-w-0">
                      <div class="font-semibold text-sm truncate"><%= file.originalName %></div>
                      <div class="md:hidden text-xs text-gray-500 mt-0.5"><%= file.category %> in <%= file.folderName %></div>
                    </div>
                  </div>
                  <div class="hidden md:block md:col-span-2 text-sm text-gray-600 truncate"><%= file.category %></div>
                  <div class="hidden sm:block sm:col-span-2 text-sm text-gray-600"><%= new Date(file.createdAt).toLocaleDateString() %></div>
                  <div class="col-span-5 sm:col-span-3 md:col-span-2 text-right text-sm font-semibold text-gray-700"><%= formatBytes(file.size) %></div>
                </a>
              <% }) %>
            </div>
          <% } %>
        </div>
      </div>
    </div>
  </main>
</div>

<%- include('../partials/modals') %>

<%- include('../partials/footer') %>
